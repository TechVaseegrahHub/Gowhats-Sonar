  }
}

async function generateAndSendTicketQR(ticket, tenant, phoneNumber, confirmationMessage, participantCount = 1, config = null) {
  try {
    console.log(`🎟️ Generating Master QR for Order: ${ticket.orderId} (Count: ${participantCount})`    );

    // ✅ PAYLOAD: Includes 'cnt' (count) so scanner knows total pax
    const qrPayload = JSON.stringify({
      oid: ticket.orderId,      // Order ID
      tid: ticket.ticketId,     // Main Ticket ID
      cnt: participantCount,    // ✅ Count for Scanner
      ph: phoneNumber,
      t_id: tenant._id.toString()
    });

    // Generate QR Buffer
    const qrBuffer = await QRCode.toBuffer(qrPayload, {
      errorCorrectionLevel: 'M',
      type: 'png',
      width: 400,
      margin: 2,
      color: { dark: '#000000', light: '#ffffff' }
    });

    const whatsappService = new WhatsAppService(tenant);

    // Upload QR to WhatsApp
    const uploadResult = await whatsappService.uploadMediaFile({
      buffer: qrBuffer,
      originalname: `ticket-${ticket.orderId}.png`,
      mimetype: 'image/png'
    }, 'image');

    // Create Caption
    const feePerPerson = config?.registrationFee || 0;
    const totalFee = feePerPerson * participantCount;
    const currencySymbol = config?.paymentGateway === 'stripe' ? 'S$' : '₹';

  let processedMessage = confirmationMessage
  .replace(/{count}/g, participantCount)
  .replace(/{total}/g, `${currencySymbol}${totalFee.toFixed(2)}`)
  .replace(/{fee}/g, `${currencySymbol}${feePerPerson.toFixed(2)}`)
  .replace(/{ticketId}/g, ticket.ticketId)
  .replace(/{name}/g, ticket.customerName || 'Guest');

let caption = `${processedMessage}\n\n`;
caption += `👥 *Admit:* ${participantCount} Person(s)\n`;
caption += `🆔 *Ticket Ref:* ${ticket.ticketId}`;
caption += `\n\n_Show this single QR code at the entrance for the whole group._`;

    // Send the Media Message
    await whatsappService.sendMediaMessage(
      phoneNumber,
      'image',
      { id: uploadResult.id },
      caption
    );

    // Save QR string to DB for reference
    ticket.qrCodeString = qrPayload;
    await ticket.save();

    return true;

  } catch (error) {
    console.error('❌ Error generating/sending QR:', error);
    // Fallback text
    try {
        const whatsappService = new WhatsAppService(tenant);
        await whatsappService.sendMessage(phoneNumber, `${confirmationMessage}\n\n(QR Failed, Order ID: ${ticket.orderId}, Admit: ${participantCount})`);
    } catch(e) {}
    return false;
  }
}


