// Helper function to ensure bot status exists
async function ensureBotStatus(tenantId) {
  try {
    let botStatus = await BotStatus.findOne({ tenantId: tenantId });
    if (!botStatus) {
      botStatus = new BotStatus({
        tenantId: tenantId,
        status: 'offline' // Default to offline
      });
      await botStatus.save();
      console.log('Created bot status for tenant:', tenantId);
