// Health check endpoint for bot functionality
router.get('/bot-health/:tenantId', async (req, res) => {
  try {
    const tenantId = req.params.tenantId;

    const [botStatus, botConfig, knowledgeBase, tenant] = await Promise.all([
      BotStatus.findOne({ tenantId }),
      BotConfiguration.findOne({ tenant_id: tenantId }),
      require('../models/KnowledgeBase').findOne({ tenantId }),
      Tenant.findById(tenantId)
    ]);

    const health = {
      tenantId,
      timestamp: new Date().toISOString(),
      botStatus: {
        exists: !!botStatus,
        status: botStatus?.status || 'unknown',
        lastUpdated: botStatus?.lastUpdated
      },
      botConfig: {
        exists: !!botConfig,
        isActive: botConfig?.isActive || false,
        triggerWords: botConfig?.triggerWords?.length || 0,
        workflows: botConfig?.workflows?.length || 0,
        welcomeMessageType: botConfig?.welcomeMessageType || 'none'
      },
      knowledgeBase: {
        exists: !!knowledgeBase,
        hasKnowledgeBase: knowledgeBase?.hasKnowledgeBase || false,
        chunksCount: knowledgeBase?.chunksCount || 0,
        embeddingsCount: knowledgeBase?.vectors?.filter(v => v.embedding?.length > 0).length || 0
      },
      tenant: {
        exists: !!tenant,
        hasWhatsAppConfig: !!(tenant?.whatsappConfig?.accessToken),
        name: tenant?.name || 'Unknown'
      },
      overall: 'unknown'
    };

    // Determine overall health
    if (health.botStatus.status === 'online' &&
      health.botConfig.isActive &&
      health.knowledgeBase.hasKnowledgeBase &&
      health.tenant.hasWhatsAppConfig) {
      health.overall = 'healthy';
    } else if (health.botStatus.exists && health.botConfig.exists) {
      health.overall = 'partial';
    } else {
      health.overall = 'unhealthy';
    }

    // Add recommendations
    health.recommendations = [];
    if (!health.botStatus.exists) {
      health.recommendations.push('Create bot status entry');
    } else if (health.botStatus.status !== 'online') {
      health.recommendations.push('Turn on bot status');
    }

    if (!health.botConfig.exists) {
      health.recommendations.push('Create bot configuration');
    } else if (!health.botConfig.isActive) {
      health.recommendations.push('Activate bot configuration');
    }

    if (!health.knowledgeBase.hasKnowledgeBase) {
      health.recommendations.push('Upload knowledge base file');
    }

    if (!health.tenant.hasWhatsAppConfig) {
      health.recommendations.push('Configure WhatsApp access token');
    }

    res.json(health);

  } catch (error) {
    res.status(500).json({
      error: error.message,
      tenantId: req.params.tenantId,
      timestamp: new Date().toISOString()
    });
  }
});

async function sendRegistrationFlow(phoneNumber, registrationConfig, tenant, metadata) {
  try {
    console.log('📋 Sending registration flow:', {
      phoneNumber,
      flowId: registrationConfig.registrationFlowId,
      tenantId: tenant._id
    });

    const WhatsAppService = require('../services/whatsappServices');
    const whatsappService = new WhatsAppService(tenant);
    const FlowToken = require('../models/FlowToken');
    const crypto = require('crypto');

    // Generate unique flow token
    const flowToken = crypto.randomBytes(32).toString('hex');

    // ✅ Use tenant-specific flow message content
    const flowPayload = {
      messaging_product: 'whatsapp',
      recipient_type: 'individual',
      to: phoneNumber,
      type: 'interactive',
      interactive: {
        type: 'flow',
        header: {
          type: 'text',
          text: registrationConfig.flowMessage?.header || '📝 Business Registration'
        },
        body: {
          text: registrationConfig.flowMessage?.body || 'Please fill out the registration form to complete your registration.'
        },
        footer: {
          text: registrationConfig.flowMessage?.footer || 'Powered by GoWhats!'
        },
        action: {
          name: 'flow',
          parameters: {
            flow_message_version: '3',
            flow_id: registrationConfig.registrationFlowId,
            flow_token: flowToken,
            flow_cta: registrationConfig.flowMessage?.ctaButtonText || 'Start Registration',
            mode: 'published',
            flow_action: 'navigate',
            flow_action_payload: {
              screen: 'REGISTRATION',
              data: {
                registration_fee: registrationConfig.registrationFee || 0,
                business_activities: [
                  { id: 'retail', title: 'Retail' },
                  { id: 'services', title: 'Services' },
                  { id: 'manufacturing', title: 'Manufacturing' },
                  { id: 'food', title: 'Food & Beverage' },
                  { id: 'technology', title: 'Technology' },
                  { id: 'healthcare', title: 'Healthcare' },
                  { id: 'ecommerce', title: 'Ecommerce' },
                  { id: 'education', title: 'Education' },
                  { id: 'construction', title: 'Construction' },
                  { id: 'transportation', title: 'Transportation' },
                  { id: 'other', title: 'Other' }
                ],
                struggles: [
                  { id: 'customers', title: 'Customer Management' },
                  { id: 'inventory', title: 'Inventory Management' },
                  { id: 'payments', title: 'Payment Collection' },
                  { id: 'marketing', title: 'Digital Marketing' },
                  { id: 'communication', title: 'Communication' },
                  { id: 'time', title: 'Time Management' },
                  { id: 'staff', title: 'Staff Management' },
                  { id: 'accounting', title: 'Accounting' },
                  { id: 'other', title: 'Other' }
                ],
                tech_solutions: [
                  { id: 'crm', title: 'CRM System' },
                  { id: 'whatsapp', title: 'WhatsApp Automation' },
                  { id: 'instagram', title: 'Instagram Automation' },
                  { id: 'ecommerce', title: 'Website Development' },
                  { id: 'inventory', title: 'Inventory Software' },
                  { id: 'payment', title: 'Payment Solutions' },
                  { id: 'marketing', title: 'Digital Marketing' },
                  { id: 'accounting', title: 'Accounting' },
                  { id: 'not_sure', title: 'Not Sure' }
                ]
              }
            }
          }
        }
      }
    };

    console.log('📤 Sending registration flow payload with custom content:', {
      header: flowPayload.interactive.header.text,
      bodyPreview: flowPayload.interactive.body.text.substring(0, 50) + '...',
      footer: flowPayload.interactive.footer.text,
      ctaButton: flowPayload.interactive.action.parameters.flow_cta
    });

    // Send flow message via WhatsApp
    const axios = require('axios');
    const response = await axios.post(
      `${whatsappService.baseUrl}/${whatsappService.phoneNumberId}/messages`,
      flowPayload,
      {
        headers: {
          Authorization: `Bearer ${whatsappService.accessToken}`,
          'Content-Type': 'application/json'
        },
        timeout: 30000
      }
    );

    if (response) {
      console.log('✅ Registration flow sent successfully:', {
        messageId: response.data.messages?.[0]?.id
      });

      // Store flow token with registration context
      await FlowToken.create({
        tenantId: tenant._id.toString(),
        token: flowToken,
        flowId: registrationConfig.registrationFlowId,
        phoneNumber: phoneNumber,
        flowType: 'registration',
        registrationConfigId: registrationConfig._id,
        status: 'active',
        createdAt: new Date()
      });

      // Save message to database
      const Message = require('../models/Message');
      const registrationFlowMessage = new Message({
        tenantId: tenant._id,
        from: metadata?.phone_number_id || tenant.whatsappConfig?.phoneNumberId || 'system',
        to: phoneNumber,
        text: 'Registration form sent',
        type: 'interactive',
        subType: 'registration_flow',
        timestamp: new Date(),
        messageId: response.data.messages?.[0]?.id,
        status: 'sent',
        isAutomatedMessage: true,
        flowId: registrationConfig.registrationFlowId,
        flowToken: flowToken
      });

      await registrationFlowMessage.save();

      // Emit to socket for real-time UI update
      if (global.io) {
        global.io.to(tenant._id.toString()).emit('message_sent', {
          ...registrationFlowMessage.toObject(),
          contact: { phone_number: phoneNumber }
        });
      }

      // Increment registration count
      await registrationConfig.incrementRegistrationCount();

      return response.data;
    }

    console.error('❌ No response from WhatsApp API');
    return null;

  } catch (error) {
    console.error('❌ Error sending registration flow:', {
      error: error.message,
      response: error.response?.data,
      phoneNumber: phoneNumber,
      tenantId: tenant._id
    });
    throw error;
  }
}

/**
 * Handle registration flow completion with proper payment logic
 */

async function handleRegistrationFlowCompletion(messageData, tenant, metadata, registrationConfig, responseJson) {
  try {
    console.log('✅ ====== REGISTRATION FLOW COMPLETION ======');

    // 1. Parse Data
    const registrationData = responseJson || JSON.parse(messageData.interactive.nfm_reply.response_json);
    console.log('📋 Raw Registration Data:', JSON.stringify(registrationData));

    // 2. ✅ FIX: Determine Participant Count with SMART FIELD DETECTION
    let participantCount = 1;

    const participantFields = [
      'participants',
      'participant_count',
      'num_participants',
      'number_of_participants',
      'pax',
      'people',
      'count',
      'total_participants'
    ];

    for (const field of participantFields) {
      if (registrationData[field]) {
        const value = parseInt(registrationData[field], 10);
        if (!isNaN(value) && value > 0 && value < 100) {
          participantCount = value;
          console.log(`✅ Participant count found in field "${field}": ${participantCount}`);
          break;
        }
      }
    }

    if (participantCount > 99) {
      console.warn(`⚠️ Suspicious participant count (${participantCount}), resetting to 1`);
      participantCount = 1;
    }

    console.log(`👥 FINAL Participant Count: ${participantCount}`);

    // 3. Calculate Amount
    const feePerTicket = registrationConfig.registrationFee || 0;
    const totalAmount = feePerTicket * participantCount;

    // ✅ NEW: Get currency based on gateway
    const currency = registrationConfig.paymentGateway === 'stripe' ? 'SGD' : 'INR';
    const currencySymbol = registrationConfig.paymentGateway === 'stripe' ? 'S$' : '₹';

    console.log('💰 Payment Calculation:', {
      feePerTicket,
      participantCount,
      totalAmount,
      currency: currency, // ✅ LOG CURRENCY
      gateway: registrationConfig.paymentGateway
    });

    // Smart Gateway Selection
    let paymentGateway = registrationConfig.paymentGateway || 'razorpay';
    if (registrationConfig.stripeConfig && registrationConfig.stripeConfig.enabled === true) {
        paymentGateway = 'stripe';
    }

    // ============================================================
    // 🔄 ORDER CREATION WITH RETRY LOGIC
    // ============================================================
    const { generateOrderId } = require('../utils/orderUtils');
    const Order = require('../models/Order');

    let newRegistrationOrder;
    let orderId;
    let savedSuccessfully = false;
    let attempts = 0;
    const MAX_RETRIES = 3;

    while (!savedSuccessfully && attempts < MAX_RETRIES) {
        attempts++;
        try {
            const rawId = await generateOrderId(tenant._id.toString());
            const prefix = registrationConfig.ticketConfig?.prefix || '';
            orderId = prefix ? `${prefix}${rawId}` : rawId;

            console.log(`🆔 Generated Ticket ID (Attempt ${attempts}): ${orderId}`);

            newRegistrationOrder = new Order({
              tenantId: tenant._id.toString(),
              orderId: orderId,
              orderNumber: rawId,
              customerPhone: messageData.from,
              customerDetails: {
                name: registrationData.name || 'Valued Guest',
                phone: messageData.from,
                email: registrationData.email || null
              },
              registrationDetails: registrationData,
              orderAmount: feePerTicket,
              totalAmount: totalAmount,
              currency: currency, // ✅ DYNAMIC CURRENCY
              status: 'pending',
              paymentStatus: 'pending',
              source: 'registration_flow',
              participantCount: participantCount,
              metadata: {
                messageId: messageData.id,
                flowCompletedAt: new Date(),
                registrationConfigId: registrationConfig._id,
                participantCount: participantCount,
                paymentGateway: paymentGateway,
                isRegistrationOrder: true,
                feePerPerson: feePerTicket,
                currency: currency // ✅ STORE CURRENCY IN METADATA
              }
            });

            await newRegistrationOrder.save();
            savedSuccessfully = true;
            console.log(`📝 Order Saved Successfully: ${orderId} (${participantCount} participants, Total: ${currency} ${totalAmount})`);

        } catch (saveError) {
            if (saveError.code === 11000) {
                console.warn(`⚠️ Duplicate Order ID ${orderId} detected. Retrying...`);
                await new Promise(resolve => setTimeout(resolve, 500));
            } else {
                throw saveError;
            }
        }
    }

    if (!savedSuccessfully) {
        throw new Error(`Failed to generate unique Order ID after ${MAX_RETRIES} attempts`);
    }

    // 4. Handle Flow Token
    const FlowToken = require('../models/FlowToken');
    if (registrationData.flow_token) {
      await FlowToken.markAsUsed(tenant._id.toString(), registrationData.flow_token, registrationData, orderId);
    }

    // ============================================================
    // 🚦 PAYMENT LOGIC
    // ============================================================
    const Settings = require('../models/settings');
    const globalSettings = await Settings.findOne({ tenant_id: tenant._id.toString() });

    const isGlobalPaymentEnabled = globalSettings?.automationConfig?.paymentRequest?.enabled !== false;
    const isEventPaymentRequired = registrationConfig.paymentRequired === true || registrationConfig.paymentRequired === "true";

    console.log(`🔍 Payment Checks: Global=${isGlobalPaymentEnabled}, Event=${isEventPaymentRequired}, Amount=${totalAmount}, Pax=${participantCount}`);

    if (isGlobalPaymentEnabled && isEventPaymentRequired && totalAmount > 0) {

      console.log(`💳 Payment Required. Sending ${paymentGateway.toUpperCase()} link for ${participantCount} pax in ${currency}...`);

      if (paymentGateway === 'stripe') {
        console.log('💳 Route: STRIPE Payment Link');
        await sendStripePaymentLink(
          messageData.from,
          registrationData,
          registrationConfig,
          tenant,
          metadata,
          orderId,
          totalAmount,
          participantCount,
          currency
        );

      } else {
        console.log('💳 Route: RAZORPAY Native Flow');
        await sendRegistrationPaymentFlow(
          messageData.from,
          registrationData,
          registrationConfig,
          tenant,
          metadata,
          orderId,
          totalAmount,
          participantCount
        );
      }

    } else {
      // ✅ FREE FLOW - Generate tickets immediately
      console.log('🎟️ Route: Payment Skipped (Free or Disabled). Generating Tickets...');

      const ticketsGenerated = await generateAndSendMultipleTickets(
        tenant,
        messageData.from,
        participantCount,
        registrationConfig,
        registrationData.name || 'Guest',
        registrationData,
        orderId
      );

      if (ticketsGenerated) {
        newRegistrationOrder.metadata.ticketsGenerated = true;
        newRegistrationOrder.metadata.ticketsGeneratedAt = new Date();
        newRegistrationOrder.status = 'confirmed';
        newRegistrationOrder.paymentStatus = 'completed';
        await newRegistrationOrder.save();
      }
      await registrationConfig.incrementRegistrationCount();
    }

    // 5. Emit Event
    if (global.io) {
      global.io.to(tenant._id.toString()).emit('registration_completed', {
        phoneNumber: messageData.from,
        orderId: orderId,
        amount: totalAmount,
        participantCount: participantCount,
        currency: currency, // ✅ EMIT CURRENCY
        gateway: paymentGateway,
        tenantId: tenant._id
      });
    }

    console.log('✅ ====== REGISTRATION FLOW COMPLETED SUCCESSFULLY ======');

  } catch (error) {
    console.error('❌ CRITICAL ERROR in Registration Flow:', error);
    try {
        const WhatsAppService = require('../services/whatsappServices');
        const ws = new WhatsAppService(tenant);
        await ws.sendMessage(messageData.from, "We received your details but encountered a system error. Our team has been notified.");
    } catch(e) {}
  }
}

/**
 * Send Stripe Payment Link via WhatsApp
 */
async function sendStripePaymentLink(phoneNumber, registrationData, registrationConfig, tenant, metadata, orderId, totalAmount, participantCount, currency) {
  try {
    const stripeService = require('../services/stripeService');
    const WhatsAppService = require('../services/whatsappServices');
    const whatsappService = new WhatsAppService(tenant);
    const axios = require('axios');

    const customerName = registrationData.name || 'Customer';

    // ✅ FIX: Auto-determine currency based on gateway
    const currency = registrationConfig.paymentGateway === 'stripe' ? 'SGD' : 'INR';
    const currencySymbol = registrationConfig.paymentGateway === 'stripe' ? 'S$' : '₹';

    // ✅ Safety check: Recalculate if needed
    let finalAmount = totalAmount;
    if (!finalAmount || finalAmount === 0) {
      const feePerTicket = registrationConfig.registrationFee || 0;
      const paxCount = participantCount || 1;
      finalAmount = feePerTicket * paxCount;
      console.log(`⚠️ Total amount recalculated: ${feePerTicket} × ${paxCount} = ${finalAmount}`);
    }

    console.log('💳 Stripe Payment Details:', {
      orderId,
      participantCount,
      feePerTicket: registrationConfig.registrationFee,
      finalAmount,
      currency: currency // ✅ DYNAMIC CURRENCY
    });

    // 1. Generate Link with DYNAMIC CURRENCY

	    const paymentLink = await stripeService.createPaymentLink({
	  amount: stripeService.toCents(finalAmount),
	  currency: currency.toLowerCase(),
	  orderId: orderId,           // ✅ top level
	  customerName: customerName,
	  customerEmail: registrationData.email,
	  customerPhone: phoneNumber,
	  description: `Event Registration - ${participantCount} Participants`,
	  metadata: {
	    orderId: orderId,                                          // ✅ must be here
	    tenantId: tenant._id.toString(),                          // ✅ must be here
	    registrationConfigId: registrationConfig._id.toString(),  // ✅ must be here
	    participantCount: participantCount.toString(),
	    isRegistrationOrder: "true",
	    feePerPerson: registrationConfig.registrationFee.toString(),
	    currency: currency
	  }
	});

    console.log('✅ Stripe Link Created:', {
      url: paymentLink.url,
      amount: `${currency} ${finalAmount.toFixed(2)}`, // ✅ DYNAMIC CURRENCY
      participants: participantCount
    });

    // 2. Prepare Button Message with DYNAMIC CURRENCY
    const headerText = registrationConfig.paymentMessage?.header || '💳 Payment Request';
    const bodyText = `${registrationConfig.paymentMessage?.body || 'Please complete your payment.'}\n\n` +
                 `📄 *Booking ID:* ${orderId}\n` +
                 `👥 *Participants:* ${participantCount}\n` +
                 `🎟️ *Fee per Person:* ${currencySymbol} ${registrationConfig.registrationFee.toFixed(2)}\n` +
                 `✖️ *No. of Tickets:* ${participantCount}\n` +
                 `━━━━━━━━━━━━━━\n` +
                 `💰 *Total Amount:* ${currencySymbol} ${finalAmount.toFixed(2)}\n\n` +
                 `Click below to complete your payment.`;

    const messagePayload = {
      messaging_product: "whatsapp",
      recipient_type: "individual",
      to: phoneNumber,
      type: "interactive",
      interactive: {
        type: "cta_url",
        header: { type: "text", text: headerText.substring(0, 60) },
        body: { text: bodyText.substring(0, 1024) },
        footer: { text: "Secure Payment via Stripe" },
        action: {
          name: "cta_url",
          parameters: {
            display_text: "Pay Now",
            url: paymentLink.url
          }
        }
      }
    };

    // 3. Send
    console.log('📤 Sending Stripe CTA Button...');
    const response = await axios.post(
      `${whatsappService.baseUrl}/${whatsappService.phoneNumberId}/messages`,
      messagePayload,
      { headers: { Authorization: `Bearer ${whatsappService.accessToken}`, 'Content-Type': 'application/json' } }
    );

    // 4. Log
    if (response.data) {
      const Message = require('../models/Message');
      await Message.create({
        tenantId: tenant._id,
        from: metadata?.phone_number_id,
        to: phoneNumber,
        text: `Stripe Link Sent: ${currencySymbol} ${finalAmount.toFixed(2)} for ${participantCount} participant(s)`,
        type: 'interactive',
        status: 'sent',
        isAutomatedMessage: true,
        orderId: orderId,
        paymentGateway: 'stripe',
        messageId: response.data.messages?.[0]?.id
      });

      console.log('✅ Payment link message saved to DB');
    }
    return response.data;

  } catch (error) {
    console.error('❌ Error sending Stripe link:', error.message);
    // Fallback
    try {
        const ws = new WhatsAppService(tenant);
        const currency = registrationConfig.paymentGateway === 'stripe' ? 'SGD' : 'INR';
        const currencySymbol = registrationConfig.paymentGateway === 'stripe' ? 'S$' : '₹';
        await ws.sendMessage(phoneNumber, `Payment Link: ${paymentLink.url}\nAmount: ${currencySymbol}${totalAmount} for ${participantCount} participant(s)`);
    } catch(e) {}
  }
}

/**
 * Send payment flow for registration
 */
async function sendRegistrationPaymentFlow(phoneNumber, registrationData, registrationConfig, tenant, metadata, orderId, totalAmount, participantCount) {
  try {
    console.log(`💳 ====== SENDING REGISTRATION PAYMENT FLOW (RAZORPAY) ======`);
    console.log(`💰 Total: ${totalAmount}, Pax: ${participantCount}`);

    const WhatsAppService = require('../services/whatsappServices');
    const whatsappService = new WhatsAppService(tenant);

    const customerName = registrationData.name || 'Customer';

    // ✅ NEW: Get currency (always INR for Razorpay)
    const currency = 'INR';
    const currencySymbol = '₹';

    // 1. Resolve Configuration Name
    let razorpayConfigName = registrationConfig.paymentConfigurationName;

    if (!razorpayConfigName) {
        const Settings = require('../models/settings');
        const globalSettings = await Settings.findOne({ tenant_id: tenant._id.toString() });

        razorpayConfigName = globalSettings?.flowConfig?.paymentConfigurationName ||
                             globalSettings?.automationConfig?.paymentRequest?.paymentConfigurationName;
    }

    if (!razorpayConfigName) {
        throw new Error('❌ Payment Failed: Razorpay Configuration Name is missing.');
    }

    // 2. Calculate Unit Price
    const count = Math.max(1, parseInt(participantCount));
    const unitPrice = totalAmount / count;

    // 3. Build Payment Payload
    const paymentOrderPayload = {
      reference_id: String(orderId),
      type: 'digital-goods',
      currency: currency, // ✅ DYNAMIC (but always INR for Razorpay)
      total_amount: {
        value: Math.round(totalAmount * 100),
        offset: 100
      },
      payment_settings: [{
        type: 'payment_gateway',
        payment_gateway: {
          type: 'razorpay',
          configuration_name: razorpayConfigName,
          razorpay: {
            receipt: String(orderId),
            notes: {
              type: 'registration',
              order_id: String(orderId),
              customer_name: customerName,
              tenant_id: tenant._id.toString(),
              participant_count: String(count),
              currency: currency // ✅ STORE CURRENCY
            }
          }
        }
      }],
      order: {
        status: 'pending',
        items: [{
          name: 'Event Ticket',
          amount: {
              value: Math.round(unitPrice * 100),
              offset: 100
          },
          quantity: count
        }],
        subtotal: {
            value: Math.round(totalAmount * 100),
            offset: 100
        }
      }
    };

    const paymentMessageConfig = {
      header: registrationConfig.paymentMessage?.header || '💳 Complete Payment',
      body: registrationConfig.paymentMessage?.body || `Please pay ${currencySymbol}${totalAmount} for ${count} ticket(s).`,
      footer: registrationConfig.paymentMessage?.footer || 'Secure Payment'
    };

    // 4. Send Message
    const paymentResponse = await whatsappService.sendPaymentOrderDetails(
      phoneNumber,
      paymentOrderPayload,
      paymentMessageConfig
    );

    if (paymentResponse) {
      console.log('✅ Razorpay payment flow sent successfully');

      const Message = require('../models/Message');
      await Message.create({
        tenantId: tenant._id,
        from: metadata?.phone_number_id,
        to: phoneNumber,
        text: `Razorpay Link Sent: ${currencySymbol}${totalAmount} for ${count} pax`,
        type: 'interactive',
        subType: 'registration_payment',
        timestamp: new Date(),
        messageId: paymentResponse.messages?.[0]?.id,
        status: 'sent',
        isAutomatedMessage: true,
        orderId: orderId
      });
    }
    return paymentResponse;

  } catch (error) {
    console.error('❌ Error sending Razorpay flow:', error);
    throw error;
  }
}


