// Rate limiting for bot responses
const botRateLimit = new Map();
const processingTickets = new Map();
const processingOrders = new Map();

function checkBotRateLimit(tenantId, phoneNumber) {
  const key = `${tenantId}_${phoneNumber}`;
  const now = Date.now();
  const windowMs = 60 * 1000; // 1 minute
  const maxRequests = 8; // INCREASED from 3 to 8 requests per minute

  if (!botRateLimit.has(key)) {
    botRateLimit.set(key, { count: 1, resetTime: now + windowMs });
    return true;
  }

  const data = botRateLimit.get(key);
  if (now > data.resetTime) {
    botRateLimit.set(key, { count: 1, resetTime: now + windowMs });
    return true;
  }

  if (data.count >= maxRequests) {
    return false;
  }

  data.count++;
  return true;
}

