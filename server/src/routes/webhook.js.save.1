        action: {
          name: 'flow',
          parameters: {
            flow_message_version: '3',
            flow_id: flowConfig.flowId,
            flow_token: flowToken,
            flow_cta: template.ctaText || 'Checkout Now',
            mode: 'published',
            flow_action: 'navigate',
            flow_action_payload: {
              screen: 'DETAILS',
              data: {
                order_total: totalAmount,
                currency: currency,
                item_count: totalItems,
                // ✅ PASS THE STATE LIST HERE
                state: stateList,
                states: stateList // Sending as both keys to be safe
              }
            }
          }
        }
      }
    };

    console.log('🚀 Sending configured flow to:', formattedPhone);

    // 5. Send Request
    const axios = require('axios');
    const response = await axios.post(
      `${whatsappService.baseUrl}/${tenant.whatsappConfig.phoneNumberId}/messages`,
      messagePayload,
      { headers: { Authorization: `Bearer ${tenant.whatsappConfig.accessToken}` } }
    );

    // 6. Save State
    if (response.data?.messages) {
      // Save Message to DB
      const flowMessage = new Message({
        tenantId: tenant._id,
        from: metadata?.phone_number_id,
        to: messageData.from,
        text: `Order Flow Sent (${totalItems} items)`,
        type: 'flow',
        subType: 'order_completion',
        status: 'sent',
        messageId: response.data.messages[0].id,
        orderData: orderData,
        flowId: flowConfig.flowId
      });
      await flowMessage.save();

      // Update Flow Token
      const FlowToken = require('../models/FlowToken');
      await FlowToken.deleteMany({ tenantId: tenant._id.toString(), phoneNumber: formattedPhone, status: 'active' });
      await FlowToken.create({
        tenantId: tenant._id.toString(),
        token: flowToken,
        flowId: flowConfig.flowId,
        phoneNumber: formattedPhone,
        flowType: 'order_completion',
        status: 'active',
        createdAt: new Date(),
        contextData: orderData
      });

      // Emit to UI
      if (global.io) {
        global.io.to(tenant._id.toString()).emit('message_sent', {
          ...flowMessage.toObject(),
          contact: { phone_number: messageData.from }
        });
      }
    }

  } catch (error) {
    console.error('❌ Error sending order flow:', error.message);
    try { await sendFallbackOrderMessage(messageData.from, orderData, tenant); } catch (e) {}
  }
};


