// Middleware to attach tenant
const attachTenant = async (req, res, next) => {
  try {
    let tenant = null;
    const requestLog = {
      hasF3Data: !!(req.body?.tenantId && req.body?.source),
      hasWhatsAppData: !!req.body?.entry?.[0]?.id,
      webhookField: req.body?.entry?.[0]?.changes?.[0]?.field, // Add this for WABA webhooks
      f3TenantId: req.body?.tenantId,
      f3Source: req.body?.source,
      businessAccountId: req.body?.entry?.[0]?.id
    };

    console.log('Tenant Resolution - Request Analysis:', requestLog);

    // Priority 1: Check for F3 integration data (WooCommerce, etc.)
    if (req.body?.tenantId && (req.body?.source === 'woocommerce_f3' || req.body?.source === 'f3_tracking')) {
      console.log(`F3 Message - Looking for tenant: ${req.body.tenantId}`);

      try {
        tenant = await Tenant.findById(req.body.tenantId);
        if (tenant) {
          console.log(`Found F3 tenant: ${tenant.name || 'Unnamed'} (${tenant._id})`);
          req.tenant = tenant;
          req.tenantSource = 'f3_direct';
          return next();
        } else {
          console.warn(`F3 tenant not found: ${req.body.tenantId}`);
        }
      } catch (err) {
        console.warn(`Invalid F3 tenant ID format: ${req.body.tenantId} - ${err.message}`);
      }
    }

    // Priority 2: Check for WhatsApp Business Account ID (regular webhooks + WABA webhooks)
    const businessAccountId = req.body?.entry?.[0]?.id;
    if (businessAccountId) {
      console.log(`WhatsApp Message - Looking for business account: ${businessAccountId}`);

      tenant = await Tenant.findOne({
        'whatsappConfig.businessAccountId': businessAccountId
      });

      if (tenant) {
        console.log(`Found WhatsApp tenant: ${tenant.name || 'Unnamed'} (${tenant._id})`);
        console.log(`Webhook field: ${requestLog.webhookField || 'messages'}`);
        console.log(`Is WABA webhook: ${['history', 'smb_app_state_sync', 'smb_message_echoes', 'account_update'].includes(requestLog.webhookField)}`);

        req.tenant = tenant;
        req.tenantSource = 'whatsapp_business_account';
        return next();
      } else {
        console.warn(`No tenant found for business account: ${businessAccountId}`);
      }
    }

    // Priority 3: Alternative F3 tenant lookup
    if (req.body?.tenantId && req.body?.source) {
      console.log(`Trying alternative F3 tenant lookup: ${req.body.tenantId}`);

      tenant = await Tenant.findOne({
        $or: [
          { _id: req.body.tenantId },
          { tenantId: req.body.tenantId },
          { 'whatsappConfig.goWhatsTenantId': req.body.tenantId }
        ]
      });

      if (tenant) {
        console.log(`Found tenant via alternative lookup: ${tenant.name || 'Unnamed'} (${tenant._id})`);
        req.tenant = tenant;
        req.tenantSource = 'f3_alternative';
        return next();
      }
    }

    // No tenant found
    console.error('No tenant found for request');
    return res.status(404).json({
      error: 'Tenant not found',
      debug: process.env.NODE_ENV === 'development' ? requestLog : undefined
    });

  } catch (error) {
    console.error('Tenant middleware error:', error);
    return res.status(500).json({ error: 'Tenant resolution failed' });
  }
};

router.post('/shopify/:integrationId', async (req, res) => {
  try {
    const integrationId = req.params.integrationId;

    // Find the integration
    const integration = await Integration.findById(integrationId);
    if (!integration) {
      console.error(`Integration not found: ${integrationId}`);
      return res.status(404).json({ error: 'Integration not found' });
    }

    // Get webhook topic and hmac
    const topic = req.headers['x-shopify-topic'] || 'unknown';
    const hmac = req.headers['x-shopify-hmac-sha256'];
    const shopifyDomain = req.headers['x-shopify-shop-domain'];

    // Get the tenant associated with this integration
    const tenant = await Tenant.findById(integration.tenantId);
    if (!tenant) {
      console.error(`Tenant not found for integration: ${integrationId}`);
      return res.status(404).json({ error: 'Tenant not found' });
    }

    // Process based on webhook topic
    switch(topic) {
      case 'orders/create':
      case 'orders/updated':
        // Handle initial order confirmation
        await integrationService.handleOrderConfirmation(req.body, tenant, 'shopify');
        break;

 // ✅ NEW: Handle Order Fulfillment/Dispatch Webhook
        case 'fulfillments/create':
          console.log(`Handling Shopify fulfillment/create for order ${req.body.order_id}`);
          if (integration.isDispatchedMessageEnabled) {
            // ✅ CHANGE FROM: await integrationService.handleOrderDispatched(...)
            // TO:
            await handleOrderDispatched(req.body, tenant, integration, 'shopify');
          }
          break;

        case 'orders/create':
        case 'orders/updated':
          // ✅ CHANGE FROM: await integrationService.handleOrderConfirmation(...)
          // TO:
          await handleOrderConfirmation(req.body, tenant, 'shopify');
          break;

        case 'carts/create':
        case 'carts/update':
          // ✅ CHANGE FROM: await integrationService.handleAbandonedCart(...)
          // TO:
          await handleAbandonedCart(req.body, tenant, 'shopify');
          break;
      default:
        console.log(`Unhandled Shopify webhook topic: ${topic}`);
    }

    // Always acknowledge receipt
    return res.status(200).json({
      success: true,
      message: 'Webhook processed successfully'
    });
  } catch (error) {
    console.error('Shopify webhook processing error:', error);
    // Still return 200 to avoid retries
    return res.status(200).json({
      success: false,
      message: 'Webhook received with errors',
      error: error.message
    });
  }
});


router.post('/razorpay/partner', async (req, res) => {
  try {
    console.log('🤝 Razorpay Partner Webhook Received:', {
      event: req.body?.event,
      timestamp: new Date().toISOString()
    });

    // Verify signature
    const crypto = require('crypto');
    const secret = process.env.RAZORPAY_PARTNER_WEBHOOK_SECRET; // Different secret for partner

    const body = JSON.stringify(req.body);
    const signature = req.headers['x-razorpay-signature'];

    const expectedSignature = crypto
      .createHmac('sha256', secret)
      .update(body)
      .digest('hex');

    if (signature !== expectedSignature) {
      console.error('❌ Invalid partner webhook signature');
      return res.status(403).json({ error: 'Invalid signature' });
    }

    const event = req.body.event;
    const payload = req.body.payload;

    // Handle different partner events
    switch (event) {
      case 'account.activated':
        console.log('✅ Merchant account activated:', payload.account.id);
        // Update merchant status in your database
        break;

      case 'account.updated':
        console.log('📝 Merchant account updated:', payload.account.id);
        break;

      case 'application.authorized':
        console.log('🔓 Application authorized for:', payload.account.id);
        // This is when a merchant authorizes your app
        // Store the account_id and other details
        break;

      case 'application.deauthorized':
        console.log('🔒 Application deauthorized for:', payload.account.id);
        // Remove access for this merchant
        break;

      default:
        console.log(`ℹ️ Unhandled partner event: ${event}`);
    }

    // Always return 200
    return res.status(200).json({ received: true });

  } catch (error) {
    console.error('❌ Partner webhook error:', error);
    return res.status(200).json({ received: true }); // Still return 200
  }
});


// Unified bot decision logic
const shouldSendBotResponse = async (messageData, tenant, contact, isNewContact) => {
  try {
    // First, ensure we are only handling text messages for bot logic.
    if (messageData.type !== 'text' || !messageData.text?.body) {
      return { shouldRespond: false, responseType: null };
    }

    const messageText = messageData.text.body.trim().toLowerCase();

    // Get the current status of the AI chatbot and the Welcome Message system.
    const [botStatus, botConfig] = await Promise.all([
      BotStatus.findOne({ tenantId: tenant._id.toString() }),
      BotConfiguration.findOne({ tenant_id: tenant._id.toString() })
    ]);

    // Determine if each system is active.
    const isChatbotActive = botStatus?.status === 'online';
    const isWelcomeActive = botConfig?.isActive === true;

    console.log('Bot Decision Check:', {
      phoneNumber: messageData.from,
      isChatbotActive,
      isWelcomeActive,
      isNewContact,
      messageText: messageText.substring(0, 50),
      contactBotMode: contact?.botMode
    });

    // PRIORITY 1: Always allow users to request a human agent
    const humanAgentKeywords = [
      'human agent', 'talk to human', 'customer service',
      'representative', 'agent', 'talk with our team'
    ];
    if (humanAgentKeywords.some(keyword => messageText.includes(keyword))) {
      console.log('Human agent requested');
      return { shouldRespond: true, responseType: 'human_agent' };
    }

    // PRIORITY 2: If the AI Chatbot system is turned off, it should never respond.
    if (!isChatbotActive) {
      console.log('AI Chatbot system is OFF. No response will be sent.');

      // But still check for welcome message
      if (isWelcomeActive) {
        const triggerWords = botConfig.triggerWords || [];
        const isTriggerWord = triggerWords.some(word => messageText.includes(word.toLowerCase()));

        // Check if a welcome message was sent in the last 3 minutes
        const recentWelcome = await Message.findOne({
          tenantId: tenant._id,
          to: messageData.from,
          isWelcomeMessage: true,
          createdAt: { $gte: new Date(Date.now() - 3 * 60 * 1000) }
        });

        if ((isTriggerWord || isNewContact) && !recentWelcome) {
          console.log('AI is off but sending welcome message for trigger/new contact');
          return { shouldRespond: true, responseType: 'welcome' };
        }
      }

      return { shouldRespond: false, responseType: null };
    }

    // Check if chatbot has knowledge base
    const KnowledgeBase = require('../models/KnowledgeBase');
    const hasKnowledgeBase = await KnowledgeBase.findOne({
      tenantId: tenant._id.toString(),
      hasKnowledgeBase: true
    });

    if (!hasKnowledgeBase) {
      console.log('AI Chatbot is ON but has no Knowledge Base.');

      // Still check for welcome message
      if (isWelcomeActive) {
        const triggerWords = botConfig.triggerWords || [];
        const isTriggerWord = triggerWords.some(word => messageText.includes(word.toLowerCase()));

        const recentWelcome = await Message.findOne({
          tenantId: tenant._id,
          to: messageData.from,
          isWelcomeMessage: true,
          createdAt: { $gte: new Date(Date.now() - 3 * 60 * 1000) }
        });

        if ((isTriggerWord || isNewContact) && !recentWelcome) {
          return { shouldRespond: true, responseType: 'welcome' };
        }
      }

      return { shouldRespond: false, responseType: null };
    }

    // CRITICAL FIX: If user is in bot mode, AI should ALWAYS respond
    if (contact?.botMode === true) {
      console.log('User is in bot mode. AI will respond directly.');
      return { shouldRespond: true, responseType: 'ai_response' };
    }

    // Handle welcome message logic
    if (isWelcomeActive) {
      const triggerWords = botConfig.triggerWords || [];
      const isTriggerWord = triggerWords.some(word => messageText.includes(word.toLowerCase()));

      const recentWelcome = await Message.findOne({
        tenantId: tenant._id,
        to: messageData.from,
        isWelcomeMessage: true,
        createdAt: { $gte: new Date(Date.now() - 3 * 60 * 1000) }
      });

      if ((isTriggerWord || isNewContact) && !recentWelcome) {
        console.log('New contact or trigger word detected. Sending welcome message.');
        return { shouldRespond: true, responseType: 'welcome' };
      }
    }

    // CRITICAL FIX: If welcome is OFF but AI is ON, respond to ALL messages
    if (isChatbotActive && !isWelcomeActive) {
      console.log('Welcome system is off, Chatbot is on. Responding with AI.');
      return { shouldRespond: true, responseType: 'ai_response' };
    }

    // Default: No response
    console.log('No specific rule met. No automated response will be sent.');
    return { shouldRespond: false, responseType: null };

  } catch (error) {
    console.error('Error in shouldSendBotResponse function:', error);
    return { shouldRespond: false, responseType: null };
  }
};

// Enhanced welcome message sender
const sendWelcomeMessage = async (phoneNumber, tenant, metadata) => {
  try {
    console.log('WELCOME MESSAGE: Starting process for:', {
      phone: phoneNumber,
      tenantId: tenant._id
    });

    const welcomeConfig = await BotConfiguration.findOne({
      tenant_id: tenant._id.toString(),
      isActive: true
    });

    if (!welcomeConfig) {
      console.error('WELCOME MESSAGE: No active bot configuration found');
      return;
    }

    if (!tenant.whatsappConfig?.accessToken) {
      console.error('WELCOME MESSAGE: Missing WhatsApp access token');
      return;
    }

    console.log('WELCOME MESSAGE: Configuration and token validated');

    const whatsappService = new WhatsAppService(tenant);

    try {
      console.log('WELCOME MESSAGE: Sending via WhatsApp service...');

      const response = await whatsappService.sendWelcomeMessage(phoneNumber, tenant._id.toString());

      if (response) {
        console.log('WELCOME MESSAGE: Successfully sent!', {
          messageId: response.messages?.[0]?.id,
          recipient: phoneNumber
        });

        const welcomeMessage = new Message({
          tenantId: tenant._id,
          from: metadata.phone_number_id,
          to: phoneNumber,
          text: welcomeConfig.messageBody,
          timestamp: new Date(),
          sent: true,
          messageId: response.messages?.[0]?.id,
          status: 'sent',
          type: 'interactive',
          isWelcomeMessage: true,
          isAutomatedMessage: true,
          excludeFromWindow: true
        });

        await welcomeMessage.save();
        console.log('WELCOME MESSAGE: Saved to database:', welcomeMessage._id);

        // Update contact to show welcome message was sent
        await Contact.findOneAndUpdate(
          {
            tenantId: tenant._id.toString(),
            phone_number: phoneNumber
          },
          {
            $set: {
              lastWelcomeMessageSent: new Date(),
              lastMessage: 'Welcome message with options'
            }
          }
        );

        // Emit to socket for real-time UI update
        if (global.io) {
          global.io.to(tenant._id.toString()).emit('message_sent', {
            ...welcomeMessage.toObject(),
            contact: { phone_number: phoneNumber }
          });

          console.log('WELCOME MESSAGE: Emitted to socket room');
        }
      } else {
        console.log('WELCOME MESSAGE: No response from WhatsApp service');
      }
    } catch (welcomeError) {
      console.error('WELCOME MESSAGE: Send error:', {
        error: welcomeError.message,
        response: welcomeError.response?.data
      });
    }

  } catch (error) {
    console.error('WELCOME MESSAGE: General error:', error);
  }
};

// Enhanced AI response handler - CORRECTED VERSION
async function handleBotResponse(messageData, tenant, metadata) {
  try {
    console.log('BOT: Generating AI response for:', {
      from: messageData.from,
      message: messageData.text?.body?.substring(0, 50),
      tenantId: tenant._id
    });

    const userMessage = messageData.text.body.trim();

    // Rate limiting check with better limits
    if (!checkBotRateLimit(tenant._id.toString(), messageData.from)) {
      console.log('BOT: Rate limit exceeded');
      const whatsappService = new WhatsAppService(tenant);

      const rateLimitResponse = await whatsappService.sendMessage(
        messageData.from,
        "I'm responding to many messages right now. Please wait a moment before asking again."
      );

      if (rateLimitResponse) {
        // Save rate limit message
        const rateLimitMessage = new Message({
          tenantId: tenant._id,
          from: metadata?.phone_number_id || tenant.whatsappConfig?.phoneNumberId || 'bot',
          to: messageData.from,
          text: "I'm responding to many messages right now. Please wait a moment before asking again.",
          type: 'text',
          timestamp: new Date(),
          messageId: rateLimitResponse.messages?.[0]?.id,
          status: 'sent',
          isBotMessage: true,
          isAutomatedMessage: true,
          isRateLimit: true
        });

        await rateLimitMessage.save();

        // Emit to UI
        if (global.io) {
          global.io.to(tenant._id.toString()).emit('message_sent', {
            ...rateLimitMessage.toObject(),
            contact: { phone_number: messageData.from }
          });
        }
      }
      return;
    }

    // CORRECTED: Use the proper bot service function
    const { findRelevantResponse } = require('../services/botService');

    let botResponse;
    try {
      console.log('BOT: Calling findRelevantResponse from botService...');
      botResponse = await findRelevantResponse(userMessage, tenant._id.toString(), messageData.from);
    } catch (aiError) {
      console.log('BOT: AI response error - using fallback:', aiError.message);
      botResponse = "Let me help you with that. Could you please be more specific about what you're looking for?";
    }

    if (botResponse && botResponse.trim()) {
      const whatsappService = new WhatsAppService(tenant);

      console.log('BOT: Sending AI response:', botResponse.substring(0, 100) + '...');

      const response = await whatsappService.sendMessage(
        messageData.from,
        botResponse
      );

      if (response) {
        const botMessage = new Message({
          tenantId: tenant._id,
          from: metadata?.phone_number_id || tenant.whatsappConfig?.phoneNumberId || 'bot',
          to: messageData.from,
          text: botResponse,
          type: 'text',
          timestamp: new Date(),
          messageId: response.messages?.[0]?.id,
          status: 'sent',
          isBotMessage: true,
          isAutomatedMessage: true
        });

        await botMessage.save();

        // CRITICAL: Maintain bot conversation state
        await Contact.findOneAndUpdate(
          {
            tenantId: tenant._id.toString(),
            phone_number: messageData.from
          },
          {
            $set: {
              lastMessage: botResponse.substring(0, 50) + (botResponse.length > 50 ? '...' : ''),
              timestamp: new Date(),
              botMode: true, // KEEP user in bot mode
              lastBotInteraction: new Date()
            }
          }
        );

        // Emit to UI
        if (global.io) {
          global.io.to(tenant._id.toString()).emit('message_sent', {
            ...botMessage.toObject(),
            contact: { phone_number: messageData.from }
          });

          console.log('BOT: AI response emitted to UI');
        }

        console.log('BOT: AI response sent successfully');
      }
    } else {
      console.log('BOT: No AI response generated - sending fallback');

      const whatsappService = new WhatsAppService(tenant);
      const fallbackMessage = "I can help you with information about our products. Please ask about specific products or type 'human agent' to speak with our team.";

      const fallbackResponse = await whatsappService.sendMessage(messageData.from, fallbackMessage);

      if (fallbackResponse) {
        const fallbackMsg = new Message({
          tenantId: tenant._id,
          from: metadata?.phone_number_id || tenant.whatsappConfig?.phoneNumberId || 'bot',
          to: messageData.from,
          text: fallbackMessage,
          type: 'text',
          timestamp: new Date(),
          messageId: fallbackResponse.messages?.[0]?.id,
          status: 'sent',
          isBotMessage: true,
          isAutomatedMessage: true,
          isFallback: true
        });

        await fallbackMsg.save();

        // Emit to UI
        if (global.io) {
          global.io.to(tenant._id.toString()).emit('message_sent', {
            ...fallbackMsg.toObject(),
            contact: { phone_number: messageData.from }
          });
        }
      }
    }

  } catch (error) {
    console.error('BOT: Error in AI response generation:', error);

    try {
      const whatsappService = new WhatsAppService(tenant);
      const errorMessage = "I'm experiencing technical difficulties. Type 'human agent' for immediate assistance.";

      const errorResponse = await whatsappService.sendMessage(messageData.from, errorMessage);

      if (errorResponse) {
        const errorMsg = new Message({
          tenantId: tenant._id,
          from: metadata?.phone_number_id || tenant.whatsappConfig?.phoneNumberId || 'bot',
          to: messageData.from,
          text: errorMessage,
          type: 'text',
          timestamp: new Date(),
          messageId: errorResponse.messages?.[0]?.id,
          status: 'sent',
          isBotMessage: true,
          isAutomatedMessage: true,
          isError: true
        });

        await errorMsg.save();

        // Emit to UI
        if (global.io) {
          global.io.to(tenant._id.toString()).emit('message_sent', {
            ...errorMsg.toObject(),
            contact: { phone_number: messageData.from }
          });
        }
      }
    } catch (fallbackError) {
      console.error('BOT: Failed to send error fallback message:', fallbackError);
    }
  }
}

