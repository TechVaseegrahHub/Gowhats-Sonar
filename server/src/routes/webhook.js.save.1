router.get('/bot-health/:tenantId', async (req, res) => {
  try {
    const tenantId = req.params.tenantId;

    const [botStatus, botConfig, knowledgeBase, tenant] = await Promise.all([
      BotStatus.findOne({ tenantId }),
      BotConfiguration.findOne({ tenant_id: tenantId }),
      require('../models/KnowledgeBase').findOne({ tenantId }),
      require('../models/Tenant').findById(tenantId)
    ]);

    const health = {
      tenantId,
      timestamp: new Date().toISOString(),

      // Separate status for chatbot and welcome message
      chatbot: {
        isActive: botStatus?.status === 'online',
        hasKnowledgeBase: !!(knowledgeBase?.hasKnowledgeBase),
        chunksCount: knowledgeBase?.chunksCount || 0,
        embeddingsCount: knowledgeBase?.vectors?.filter(v => v.embedding?.length > 0).length || 0,
        status: botStatus?.status || 'offline',
        lastUpdated: botStatus?.lastUpdated
      },

      welcomeMessage: {
        isActive: botConfig?.isActive || false,
        hasConfiguration: !!botConfig,
        triggerWords: botConfig?.triggerWords?.length || 0,
        workflows: botConfig?.workflows?.length || 0,
        messageType: botConfig?.welcomeMessageType || 'none'
      },

      tenant: {
        exists: !!tenant,
        hasWhatsAppConfig: !!(tenant?.whatsappConfig?.accessToken),
        name: tenant?.name || 'Unknown'
      }
    };

    // Determine system behavior
    health.systemBehavior = {
      chatbotWillRespond: health.chatbot.isActive && health.chatbot.hasKnowledgeBase,
      welcomeMessageWillSend: health.welcomeMessage.isActive && health.welcomeMessage.hasConfiguration,
      currentMode: health.welcomeMessage.isActive ?
        (health.chatbot.isActive ? 'Both Active (Welcome Priority)' : 'Welcome Message Only') :
        (health.chatbot.isActive ? 'Chatbot Only' : 'Both Inactive')
    };

    // Add recommendations
    health.recommendations = [];

    if (!health.chatbot.isActive && !health.welcomeMessage.isActive) {
      health.recommendations.push('⚠️ Both chatbot and welcome message are inactive');
    }

    if (health.chatbot.isActive && !health.chatbot.hasKnowledgeBase) {
      health.recommendations.push('❌ Chatbot is ON but no knowledge base uploaded');
    }

    if (health.welcomeMessage.isActive && !health.welcomeMessage.hasConfiguration) {
      health.recommendations.push('❌ Welcome message is ON but not configured');
    }

    if (!health.tenant.hasWhatsAppConfig) {
      health.recommendations.push('❌ WhatsApp configuration missing');
    }

    if (health.recommendations.length === 0) {
      health.recommendations.push('✅ System configured correctly');
    }

    res.json(health);

  } catch (error) {
    res.status(500).json({
      error: error.message,
      tenantId: req.params.tenantId,
      timestamp: new Date().toISOString()
    });
  }
});

// Handle human agent requests
async function handleHumanAgentRequest(messageData, tenant, metadata) {
  try {
    console.log('Human agent requested by:', messageData.from);

    // Update contact to mark human agent request
    const updatedContact = await Contact.findOneAndUpdate(
      {
        tenantId: tenant._id.toString(),
        phone_number: messageData.from
      },
      {
        $set: {
          botMode: false,
          humanAgentRequested: true, // NEW: Mark as human agent requested
          lastHumanAgentRequest: new Date(),
          humanAgentStatus: 'requested', // NEW: Set status
          lastMessage: 'Requested human agent'
        }
      },
      { upsert: true, new: true }
    );

    const whatsappService = new WhatsAppService(tenant);

    // Get custom message from bot config if available
    const botConfig = await BotConfiguration.findOne({
      tenant_id: tenant._id.toString()
    });

    let agentMessage = "🙋‍♀️ Connecting you with our human agent...\n\nOur team will assist you shortly. Thank you for your patience! ❤️";

    // Try to get custom "Talk with Our Team" message
    if (botConfig?.workflowMessages) {
      const customMessage = botConfig.workflowMessages.find(
        wm => wm.workflow === 'Talk with Our Team'
      );
      if (customMessage?.message) {
        agentMessage = customMessage.message;
      }
    }

    agentMessage += "\n\nPowered by GoWhats!";

    const response = await whatsappService.sendMessage(messageData.from, agentMessage);

    if (response) {
      const agentRequestMessage = new Message({
        tenantId: tenant._id,
        from: metadata?.phone_number_id || tenant.whatsappConfig?.phoneNumberId || 'system',
        to: messageData.from,
        text: agentMessage,
        type: 'text',
        timestamp: new Date(),
        messageId: response.messages?.[0]?.id,
        status: 'sent',
        isHumanAgentRequest: true
      });

      await agentRequestMessage.save();

      if (global.io) {
        global.io.to(tenant._id.toString()).emit('message_sent', {
          ...agentRequestMessage.toObject(),
          contact: { phone_number: messageData.from }
        });

        // Emit human agent request event with updated contact
        global.io.to(tenant._id.toString()).emit('human_agent_requested', {
          phoneNumber: messageData.from,
          tenantId: tenant._id,
          requestedAt: new Date(),
          customerName: messageData.profile?.name || 'Customer',
          updatedContact: updatedContact
        });

        // Emit contact update to refresh the UI
        global.io.to(tenant._id.toString()).emit('contact_updated', {
          contact: updatedContact,
          tenantId: tenant._id.toString(),
          timestamp: new Date(),
          action: 'human_agent_requested'
        });
      }
    }

    console.log('Human agent request processed successfully');

  } catch (error) {
    console.error('Error handling human agent request:', error);
  }
}


// Enhanced broadcast status update function with real-time emission
async function updateBroadcastStatusWithRealTimeEmit(broadcastId, messageId, messageStatus, recipientPhone, tenantId) {
  try {
    const Broadcast = require('../models/Broadcast');
    const Message = require('../models/Message'); // ✅ Import Message model

    // 1. Find the Broadcast
    const broadcast = await Broadcast.findById(broadcastId);
    if (!broadcast) {
      console.log(`Broadcast not found for ID: ${broadcastId}`);
      return;
    }

    // 2. ✅ FIX: Find the local Message document to get the correct ObjectId
    const messageDoc = await Message.findOne({ messageId: messageId });

    if (!messageDoc) {
        // Suppress warning to avoid log noise for fast updates
        return;
    }

    // Use the MongoDB _id (ObjectId), not the wamid string
    const dbMessageId = messageDoc._id;

    let statusChanged = false;
    let countsChanged = false;

    if (!broadcast.sentMessages) broadcast.sentMessages = [];
    if (!broadcast.deliveredMessages) broadcast.deliveredMessages = [];
    if (!broadcast.readMessages) broadcast.readMessages = [];
    if (!broadcast.failedMessages) broadcast.failedMessages = [];

    // Helper to check if ID exists (handling ObjectId comparison safely)
    const hasId = (array, id) => array.some(existingId => existingId.toString() === id.toString());

    switch (messageStatus) {
      case 'sent':
        if (!hasId(broadcast.sentMessages, dbMessageId)) {
          broadcast.sentMessages.push(dbMessageId);
          broadcast.sentCount = broadcast.sentMessages.length;
          countsChanged = true;
          console.log(`Updated sent count for broadcast ${broadcastId}: ${broadcast.sentCount}`);
        }
        break;

      case 'delivered':
        if (!hasId(broadcast.deliveredMessages, dbMessageId)) {
          broadcast.deliveredMessages.push(dbMessageId);
          broadcast.deliveredCount = broadcast.deliveredMessages.length;
          countsChanged = true;
          console.log(`Updated delivered count for broadcast ${broadcastId}: ${broadcast.deliveredCount}`);
        }
        break;

      case 'read':
        if (!hasId(broadcast.readMessages, dbMessageId)) {
          broadcast.readMessages.push(dbMessageId);
          broadcast.readCount = broadcast.readMessages.length;
          countsChanged = true;
          console.log(`Updated read count for broadcast ${broadcastId}: ${broadcast.readCount}`);
        }
        break;

      case 'failed':
        if (!hasId(broadcast.failedMessages, dbMessageId)) {
          broadcast.failedMessages.push(dbMessageId);
          broadcast.failedCount = broadcast.failedMessages.length;
          countsChanged = true;
          console.log(`Updated failed count for broadcast ${broadcastId}: ${broadcast.failedCount}`);
        }
        break;
    }

    const totalRecipients = broadcast.recipients ? broadcast.recipients.length : 0;
    const sentCount = broadcast.sentCount || 0;
    const failedCount = broadcast.failedCount || 0;

    // ✅ FIX: Use lowercase 'completed' to match Mongoose Enum
    if (sentCount + failedCount >= totalRecipients && broadcast.status !== 'completed') {
      broadcast.status = 'completed';
      statusChanged = true;
    }
    // ✅ FIX: Use lowercase 'processing' instead of 'In Progress'
    else if (sentCount > 0 && (broadcast.status === 'pending' || broadcast.status === 'scheduled')) {
      broadcast.status = 'processing';
      statusChanged = true;
    }

    if (statusChanged || countsChanged) {
      broadcast.lastStatusUpdate = new Date();
      await broadcast.save();

      const newCounts = {
        sent: broadcast.sentCount || 0,
        delivered: broadcast.deliveredCount || 0,
        read: broadcast.readCount || 0,
        failed: broadcast.failedCount || 0
      };

      if (global.io && tenantId) {
        const updateData = {
          broadcastId: broadcastId,
          messageId: messageId,
          messageStatus: messageStatus,
          recipientPhone: recipientPhone,
          broadcast: {
            id: broadcast._id,
            name: broadcast.name,
            status: broadcast.status,
            sentCount: newCounts.sent,
            deliveredCount: newCounts.delivered,
            readCount: newCounts.read,
            failedCount: newCounts.failed,
            totalRecipients: totalRecipients,
            progress: totalRecipients > 0 ? Math.round((newCounts.sent / totalRecipients) * 100) : 0
          },
          timestamp: new Date().toISOString(),
          countsChanged: countsChanged,
          statusChanged: statusChanged
        };

        global.io.to(tenantId).emit('broadcast_status_update', updateData);
        global.io.to(tenantId).emit('broadcast_update', updateData);

        const broadcastRoom = `broadcast_${broadcastId}_${tenantId}`;
        global.io.to(broadcastRoom).emit('broadcast_detailed_update', updateData);

        // ✅ FIX: Check for lowercase 'completed'
        if (broadcast.status === 'completed' && statusChanged) {
          global.io.to(tenantId).emit('broadcast_completed', {
            broadcastId: broadcast._id,
            name: broadcast.name,
            status: 'completed',
            finalCounts: newCounts,
            totalRecipients: totalRecipients,
            completedAt: new Date().toISOString()
          });
        }
      }
    }

  } catch (error) {
    console.error('Error updating broadcast status:', {
      error: error.message,
      broadcastId,
      messageId,
      messageStatus
    });
  }
}

// Handle payment status updates
// ✅ FIXED: Payment Handler with Proper Participant Count Retrieval
async function handlePaymentStatusUpdate(paymentStatus, tenant, metadata) {
  try {
    const { recipient_id: customerPhone, status, payment } = paymentStatus;
    const { reference_id: orderId, transaction } = payment;

    console.log('💳 Payment Update:', { orderId, status, tenantId: tenant._id });

    // ✅ CRITICAL: Check if already processing
    const processingKey = `${tenant._id}-${orderId}`;
    if (processingOrders.has(processingKey)) {
      console.log('⚠️ DUPLICATE PAYMENT WEBHOOK IGNORED');
      return;
    }

    // ✅ Mark as processing
    processingOrders.set(processingKey, Date.now());

    // ✅ Auto-cleanup after 5 minutes
    setTimeout(() => {
      processingOrders.delete(processingKey);
    }, 5 * 60 * 1000);

    const order = await Order.findOne({
        tenantId: tenant._id.toString(),
        orderId: orderId
    });

    if (!order) {
        console.warn(`Order not found for payment: ${orderId}`);
        processingOrders.delete(processingKey);
        return;
    }

    // ✅ CRITICAL: Check if already processed
    if (order.paymentStatus === 'completed' && order.metadata?.ticketsGenerated) {
      console.log('✅ SKIP: Tickets already generated for this order');
      processingOrders.delete(processingKey);
      return;
    }

    // Handle Successful Payment
    if (status === 'captured' && transaction?.status === 'success') {
      console.log('✅ Payment captured successfully!');

      order.paymentStatus = 'completed';
      order.status = 'confirmed';
      order.confirmedAt = new Date();

      if (!order.paymentDetails) order.paymentDetails = {};
      order.paymentDetails = {
        ...order.paymentDetails,
        status: 'completed',
        transactionId: transaction.id,
        amount: payment.amount?.value / 100,
        currency: payment.currency
      };

      if (!order.metadata) order.metadata = {};
      order.metadata.ticketsGenerating = true;

      await order.save();

      // ✅ Generate tickets for registration orders
      if (order.source === 'registration_flow') {
        console.log('🎟️ Registration Payment Confirmed - Generating Tickets...');

        // ✅ FIX: Get participant count from MULTIPLE sources (top level OR metadata)
        const participantCount = order.participantCount ||
                                order.metadata?.participantCount ||
                                order.metadata?.totalPax ||
                                1;

        console.log(`👥 Retrieved Participant Count:`, {
          fromTopLevel: order.participantCount,
          fromMetadata: order.metadata?.participantCount,
          fromTotalPax: order.metadata?.totalPax,
          finalCount: participantCount
        });

        // ✅ FIX: Get config using saved reference
        let regConfig;

        if (order.metadata?.registrationConfigId) {
          regConfig = await RegistrationConfig.findById(order.metadata.registrationConfigId);
          console.log(`✅ Found config by ID: ${order.metadata.registrationConfigId}`);
        } else {
          // Fallback to tenant lookup
          regConfig = await RegistrationConfig.findOne({
            tenantId: tenant._id,
            isActive: true
          });
          console.log('⚠️ Using fallback config lookup');
        }

        if (regConfig) {
          console.log(`🎫 Generating ${participantCount} ticket(s) for Order: ${order.orderId}`);

          const ticketsGenerated = await generateAndSendMultipleTickets(
            tenant,
            customerPhone,
            participantCount, // ✅ Now using correct count from order metadata
            regConfig,
            order.customerDetails.name,
            order.registrationDetails,
            order.orderId // ✅ This is already EV101 format
          );

          if (ticketsGenerated) {
            order.metadata.ticketsGenerated = true;
            order.metadata.ticketsGenerating = false;
            order.metadata.ticketsGeneratedAt = new Date();
            await order.save();
            console.log('✅ Tickets marked as generated in order');
          } else {
            console.error('❌ Ticket generation failed');
            order.metadata.ticketsGenerating = false;
            order.metadata.ticketGenerationFailed = true;
            await order.save();
          }
        } else {
          console.error('❌ Registration config not found for ticket generation');
          order.metadata.ticketsGenerating = false;
          await order.save();
        }
      } else {
        // Standard E-commerce Confirmation
        await sendOrderConfirmationMessage(order, customerPhone, tenant, metadata);
      }

      processingOrders.delete(processingKey);
    }
    // Handle Failed Payment
    else if (transaction?.status === 'failed') {
      order.paymentStatus = 'failed';
      await order.save();
      processingOrders.delete(processingKey);

      const whatsappService = new WhatsAppService(tenant);
      await whatsappService.sendMessage(customerPhone, "❌ Payment failed. Please try again to secure your booking.");
    } else {
      processingOrders.delete(processingKey);
    }

    // Emit socket update
    if (global.io) {
      global.io.to(tenant._id.toString()).emit('payment_status_update', {
        orderId,
        status: order.paymentStatus,
        tenantId: tenant._id
      });
    }

  } catch (error) {
    console.error('❌ Payment Handler Error:', error);
    const processingKey = `${tenant._id}-${payment?.reference_id}`;
    processingOrders.delete(processingKey);
  }
}


// Send order confirmation message after successful payment
async function sendOrderConfirmationMessage(order, customerPhone, tenant, metadata) {
  try {
    // 1. Fetch Settings safely
    const Settings = require('../models/settings');
    let settings = await Settings.findOne({ tenant_id: tenant._id.toString() });

    // 2. Default config if settings are missing
    let confirmConfig = settings?.automationConfig?.orderConfirmation;

    // 3. Check if explicitly disabled
    if (confirmConfig && confirmConfig.enabled === false) {
       console.log('🔕 Order Confirmation disabled for tenant:', tenant._id);
       return;
    }

    console.log('✅ Sending order confirmation for:', order.orderId);

    // 4. Prepare Message (Use fallback if template is missing)
    let messageBody = confirmConfig?.template?.body;

    if (!messageBody) {
        messageBody = "✅ Thank you! Your order *{{order_id}}* has been confirmed.\nAmount: {{amount}}";
    }

    // 5. Replace Variables (Add safety checks)
    const amountStr = order.totalAmount ? order.totalAmount.toFixed(2) : '0.00';
    const currency = order.currency || 'INR';
    const itemsCount = order.items ? order.items.length : 0;
    const custName = order.customerDetails?.name || 'Customer';

    messageBody = messageBody
      .replace('{{order_id}}', order.orderId)
      .replace('{{amount}}', `${currency} ${amountStr}`)
      .replace('{{items}}', itemsCount)
      .replace('{{customer}}', custName);

    // Append Footer
    messageBody += "\n\nPowered by GoWhats!";

    const whatsappService = new WhatsAppService(tenant);
    const response = await whatsappService.sendMessage(customerPhone, messageBody);

    if (response) {
      await Message.create({
        tenantId: tenant._id,
        from: metadata?.phone_number_id,
        to: customerPhone,
        text: messageBody,
        type: 'text',
        status: 'sent',
        messageId: response.messages?.[0]?.id, // Add null check here
        isOrderConfirmation: true
      });
      console.log('✅ Order confirmation sent successfully');
    }

  } catch (error) {
    console.error('❌ Error sending confirmation:', error);
  }
}


async function isTriggerWord(messageText, tenant) {
  try {
    if (!messageText || typeof messageText !== 'string') {
      return false;
    }

    // Get bot configuration for this tenant
    const botConfig = await BotConfiguration.findOne({
      tenant_id: tenant._id.toString(),
      isActive: true
    });

    if (!botConfig || !botConfig.triggerWords || !Array.isArray(botConfig.triggerWords)) {
      return false;
    }

    const normalizedMessage = messageText.trim().toLowerCase();

    // Check if message contains any trigger words
    return botConfig.triggerWords.some(word =>
      normalizedMessage.includes(word.toLowerCase())
    );

  } catch (error) {
    console.error('Error checking trigger word:', error);
    return false;
  }
}

// Helper function to process message by type
async function processMessageByType(messageData, tenant, metadata) {
  const type = messageData.type;
  let details = {
    text: '',
    lastMessageText: '',
    mediaUrl: '',
    s3Key: '',
    storage: 's3',
    caption: '',
    filename: '',
    isFlowCompletion: false,
    isInteractiveResponse: false,
    quotedMessage: null,  // ✅ NEW
    replyTo: null         // ✅ NEW
  };

  // ✅ NEW: Check if message is a reply
  if (messageData.context && messageData.context.id) {
    console.log('📎 Message is a reply to:', messageData.context.id);

    try {
      const originalMessage = await Message.findOne({
        tenantId: tenant._id.toString(),
        messageId: messageData.context.id
      });

      if (originalMessage) {
        console.log('✅ Found original message:', originalMessage._id);

        details.quotedMessage = {
          messageId: originalMessage.messageId,
          text: originalMessage.text || '',
          from: originalMessage.from,
          timestamp: originalMessage.timestamp,
          type: originalMessage.type,
          mediaUrl: originalMessage.mediaUrl,
          senderName: originalMessage.from === tenant.whatsappConfig?.phoneNumberId
            ? 'You'
            : (originalMessage.from || 'Contact')
        };

        details.replyTo = originalMessage._id;
      } else {
        console.warn('⚠️ Original message not found');

        details.quotedMessage = {
          messageId: messageData.context.id,
          text: 'Original message not available',
          from: 'Unknown',
          timestamp: new Date(),
          type: 'text'
        };
      }
    } catch (error) {
      console.error('❌ Error looking up quoted message:', error);
    }
  }

  switch (type) {
    case 'text':
      details.text = messageData.text?.body || '';
      details.lastMessageText = details.text;
      break;

    case 'button':
      details.text = messageData.button?.text || 'Button reply';
      details.lastMessageText = details.text;
      break;

    case 'interactive':
      if (messageData.interactive?.type === 'list_reply') {
        details.text = messageData.interactive.list_reply?.title || 'Interactive message';
        details.lastMessageText = details.text;
      } else if (messageData.interactive?.type === 'button_reply') {
        details.text = messageData.interactive.button_reply?.title || 'Button press';
        details.lastMessageText = details.text;
      } else if (messageData.interactive?.type === 'nfm_reply') {
        console.log('Flow completion response detected');
        const flowReply = messageData.interactive.nfm_reply;
        details.isFlowCompletion = true;
        details.text = flowReply?.body || 'Flow completed successfully';
        details.lastMessageText = 'Order form completed';

        if (flowReply?.response_json) {
          try {
            const flowResponseData = JSON.parse(flowReply.response_json);
          details.flowResponseData = flowResponseData;

              // Detect flow type from response fields
              const isRegistrationFlow =
                  flowResponseData.num_participants !== undefined ||
                  flowResponseData.participants !== undefined ||
                  flowResponseData.participant_count !== undefined;

              details.text = isRegistrationFlow
                  ? 'Registration details submitted successfully'
                  : 'Order details submitted successfully';

              details.lastMessageText = isRegistrationFlow
                  ? 'Registration details submitted'
                  : 'Order details submitted';

    } catch (parseError) {
            console.error('Error parsing flow response JSON:', parseError);
            details.text = 'Flow completed (parsing error)';
            details.lastMessageText = 'Flow completed';
          }
        }
      } else {
        details.text = 'Interactive message';
        details.lastMessageText = details.text;
      }

      details.isInteractiveResponse = true;
      details.interactiveData = messageData.interactive;
      break;

     case 'order':
          console.log('📦 Processing order data:', JSON.stringify(messageData.order, null, 2));

          const originalOrderData = messageData.order;
          let totalPrice = 0;
          const formattedItems = [];

          if (originalOrderData.product_items && originalOrderData.product_items.length > 0) {
            for (const item of originalOrderData.product_items) {
              let inventoryItem = null;

              try {
                inventoryItem = await InventoryItem.findOne({
                  tenant_id: tenant._id.toString(),
                  retailer_id: item.product_retailer_id
                });
              } catch (err) {
                console.error('Error looking up inventory item:', err);
              }

              const itemPrice = parseFloat(item.item_price || 0);
              const quantity = parseInt(item.quantity || 1);
              const itemTotal = itemPrice * quantity;
              totalPrice += itemTotal;

              formattedItems.push({
                retailer_id: item.product_retailer_id,  // ✅ CRITICAL: Include retailer_id
                id: item.product_retailer_id,
                name: inventoryItem?.name || item.title || item.product_retailer_id,
                price: itemPrice,
                item_price: itemPrice,  // ✅ Add both for compatibility
                quantity: quantity,
                subtotal: itemTotal,
                currency: item.currency || inventoryItem?.currency || 'INR',
                image_url: inventoryItem?.image_url || item.thumbnail_url || null,
                additional_images: inventoryItem?.additional_images || []
              });
            }
          }

          const itemNames = formattedItems.map(item => `${item.name} (${item.quantity}x)`).join(', ');
          details.text = `Order: ${itemNames} - Total: ${originalOrderData.product_items?.[0]?.currency || 'INR'} ${totalPrice.toFixed(2)}`;
          details.lastMessageText = `Order: ${formattedItems.length} item(s) - ${originalOrderData.product_items?.[0]?.currency || 'INR'} ${totalPrice.toFixed(2)}`;

          // ✅ CRITICAL FIX: Properly structure orderData with all required fields
          details.orderData = {
            catalog_id: originalOrderData.catalog_id,
            text: originalOrderData.text || details.text,
            items: formattedItems,  // ✅ Array with retailer_id included
            total: totalPrice.toFixed(2),
            currency: originalOrderData.product_items?.[0]?.currency || 'INR',
            order_id: 'ORD-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9),
            raw_order_data: originalOrderData
          };

          console.log('✅ Order data structured:', {
            itemsCount: details.orderData.items.length,
            total: details.orderData.total,
            currency: details.orderData.currency,
            hasRetailerIds: details.orderData.items.every(item => item.retailer_id)
          });
          break;

    default:
      if (mediaTypes.includes(type)) {
        const mediaTypeData = messageData[type];
        details.caption = mediaTypeData?.caption || '';
        details.filename = mediaTypeData?.filename || '';

        const mediaTypeLabels = {
          'image': 'Photo',
          'video': 'Video',
          'audio': 'Audio message',
          'document': 'Document'
        };

        details.lastMessageText = mediaTypeLabels[type] || `${type.charAt(0).toUpperCase() + type.slice(1)} message`;

        if (mediaTypeData?.id) {
          try {
            const mediaResult = await downloadMediaFromWhatsApp(
              mediaTypeData.id,
              tenant.whatsappConfig.accessToken,
              tenant._id.toString()
            );

            if (mediaResult) {
              details.mediaUrl = mediaResult.url;
              details.s3Key = mediaResult.s3Key;
              details.storage = 's3';
              details.mimeType = mediaResult.mimeType;
              details.text = mediaTypeData.caption || mediaTypeData.filename || details.lastMessageText;
            }
          } catch (err) {
            console.error(`Failed to process ${type}:`, err);
            details.text = `${type.charAt(0).toUpperCase() + type.slice(1)} message (media unavailable)`;
          }
        }
      } else {
        details.text = `${type.charAt(0).toUpperCase() + type.slice(1)} message`;
        details.lastMessageText = `${type.charAt(0).toUpperCase() + type.slice(1)} message`;
      }
      break;
  }

  return details;
}

async function handleContactForWebhook(messageData, contactData, tenant, metadata) {
  const phoneNumber = messageData.from;
  const tenantId = tenant._id.toString();

  console.log('Processing contact for webhook:', {
    phoneNumber,
    tenantId,
    messageType: messageData.type,
    hasContactData: !!contactData
  });

  try {
    const getLastMessage = (messageData) => {
      if (messageData.type === 'text' && messageData.text?.body) {
        return messageData.text.body.substring(0, 100);
      } else if (messageData.type === 'interactive') {
        return 'Interactive message';
      } else if (messageData.type === 'order') {
        return 'Order placed';
      } else {
        return `${messageData.type.charAt(0).toUpperCase() + messageData.type.slice(1)} message`;
      }
    };

    const lastMessage = getLastMessage(messageData);
    const messageTimestamp = new Date(parseInt(messageData.timestamp) * 1000);

    const getContactName = (contactData, phoneNumber) => {
      if (contactData?.profile?.name && contactData.profile.name.trim()) {
        return contactData.profile.name.trim();
      }
      const cleanPhone = phoneNumber.replace(/^\+?91/, '').replace(/^91/, '');
      return cleanPhone;
    };

    const contactName = getContactName(contactData, phoneNumber);

    // Check if contact exists
    let existingContact = await Contact.findOne({
      tenantId: tenantId,
      phone_number: phoneNumber
    });

    const isNewContact = !existingContact;

    // Use findOneAndUpdate with upsert for atomic operation
    const contact = await Contact.findOneAndUpdate(
      {
        tenantId: tenantId,
        phone_number: phoneNumber
      },
      {
        $set: {
          profile_name: contactData?.profile?.name || null,
          name: contactName,
          lastMessage: lastMessage,
          lastMessageType: messageData.type,
          timestamp: messageTimestamp,
          source: 'whatsapp',
          status: 'active'
        },
        $inc: { unreadCount: 1 }
      },
      {
        upsert: true,
        new: true,
        setDefaultsOnInsert: true
      }
    );

    console.log('Contact upsert successful:', {
      contactId: contact._id,
      name: contact.name,
      phoneNumber: contact.phone_number,
      isNew: isNewContact
    });

    // Emit new contact immediately for real-time updates
    if (isNewContact && global.io) {
      console.log('NEW CONTACT - Emitting to UI:', contact.phone_number);

      global.io.to(tenantId).emit('new_contact', {
        contact: contact.toObject(),
        tenantId: tenantId,
        timestamp: new Date(),
        isNewContact: true
      });

      // Also emit contact updated
      global.io.to(tenantId).emit('contact_updated', {
        contact: contact.toObject(),
        tenantId: tenantId,
        timestamp: new Date(),
        action: 'new_contact'
      });
    }

    return contact;

  } catch (error) {
    console.error('Contact handling error:', error);

    // Create minimal contact object for continued processing
    const getContactName = (contactData, phoneNumber) => {
      if (contactData?.profile?.name && contactData.profile.name.trim()) {
        return contactData.profile.name.trim();
      }
      const cleanPhone = phoneNumber.replace(/^\+?91/, '').replace(/^91/, '');
      return cleanPhone;
    };

    const getLastMessage = (messageData) => {
      if (messageData.type === 'text' && messageData.text?.body) {
        return messageData.text.body.substring(0, 100);
      } else if (messageData.type === 'interactive') {
        return 'Interactive message';
      } else if (messageData.type === 'order') {
        return 'Order placed';
      } else {
        return `${messageData.type.charAt(0).toUpperCase() + messageData.type.slice(1)} message`;
      }
    };

    const fallbackContact = {
      _id: new mongoose.Types.ObjectId(),
      tenantId: tenantId,
      phone_number: phoneNumber,
      profile_name: contactData?.profile?.name || null,
      name: getContactName(contactData, phoneNumber),
      lastMessage: getLastMessage(messageData),
      timestamp: new Date(),
      unreadCount: 1,
      source: 'whatsapp',
      toObject: function () { return this; }
    };

    // Emit fallback contact as new contact
    if (global.io) {
      global.io.to(tenantId).emit('new_contact', {
        contact: fallbackContact,
        tenantId: tenantId,
        timestamp: new Date(),
        isNewContact: true
      });
    }

    return fallbackContact;
  }
}

function emitMessageToSocket(tenant, newMessage, contact, metadata) {
  if (global.io) {
    const messageData = {
      ...newMessage.toObject(),
      contact: contact.toObject ? contact.toObject() : contact,
      metadata: metadata
    };

    // ✅ CRITICAL: Add unique emission ID to prevent double-processing
    const emissionId = `${newMessage._id || newMessage.messageId}-${Date.now()}`;
    messageData._emissionId = emissionId;

    console.log('🔥 EMITTING MESSAGE TO UI:', {
      messageId: newMessage._id,
      emissionId: emissionId,
      from: newMessage.from,
      type: newMessage.type,
      text: newMessage.text?.substring(0, 30) + '...',
      mediaUrl: newMessage.mediaUrl?.substring(0, 50),
      tenantId: tenant._id
    });

    // Emit to tenant room
    global.io.to(tenant._id.toString()).emit('receive_message', messageData);

    // Also emit to specific chat room for real-time updates
    const chatRoom = `chat_${tenant._id}_${newMessage.from}`;
    global.io.to(chatRoom).emit('receive_message', messageData);

    // Emit contact update
    global.io.to(tenant._id.toString()).emit('contact_updated', {
      contact: contact.toObject ? contact.toObject() : contact,
      tenantId: tenant._id.toString(),
      timestamp: new Date(),
      action: 'message_received'
    });

    // Emit new contact event if it's a new contact
    global.io.to(tenant._id.toString()).emit('new_contact_message', {
      contact: contact.toObject ? contact.toObject() : contact,
      message: messageData,
      tenantId: tenant._id.toString(),
      timestamp: new Date()
    });

    console.log('✅ Message emitted to socket rooms successfully');
  }
}

const sendOrderFlowMessage = async (orderData, messageData, tenant, metadata) => {
  try {
    console.log('🔄 Processing order flow trigger for:', messageData.from);

    // 1. Fetch Tenant Settings
    const Settings = require('../models/settings');
    let settings;
    // Handle static vs instance method availability
    if (typeof Settings.initializeForTenant === 'function') {
      settings = await Settings.initializeForTenant(tenant._id.toString());
    } else {
      settings = await Settings.findOne({ tenant_id: tenant._id.toString() });
    }

    if (!settings) {
      console.warn('No settings found, using fallback.');
      return await sendFallbackOrderMessage(messageData.from, orderData, tenant);
    }

    // 2. Check Configuration
    const flowConfig = settings.automationConfig?.orderFlow;

    // Check if enabled (defaulting to false if undefined to be safe)
    if (!flowConfig?.enabled) {
      console.log(`🔕 Order Flow is DISABLED for tenant: ${tenant._id}`);
      // Optional: Send text fallback
      const whatsappService = new WhatsAppService(tenant);
      await whatsappService.sendMessage(messageData.from, "Thank you! We have received your cart and will process it manually.");
      return;
    }

    if (!flowConfig.flowId) {
      console.error('❌ Flow ID missing in settings');
      return await sendFallbackOrderMessage(messageData.from, orderData, tenant);
    }

    // 3. Prepare Data
    const whatsappService = new WhatsAppService(tenant);
    const formattedPhone = whatsappService.formatPhoneNumber(messageData.from);
    const flowToken = require('crypto').randomBytes(32).toString('hex');

    const totalItems = orderData.items?.length || 0;
    const totalAmount = orderData.total || '0';
    const currency = orderData.currency || 'INR';

    const template = flowConfig.template || {};

    // ✅ FIX: Define State List (This was missing)
