    // ✅ DEBUG: Check what we received
    console.log('🔍 Request Body Type:', {
      typeOf: typeof req.body,
      isBuffer: Buffer.isBuffer(req.body),
      bodyConstructor: req.body?.constructor?.name,
      hasRawBody: !!req.rawBody,
      rawBodyType: req.rawBody ? typeof req.rawBody : 'none'
    });

    // ✅ CRITICAL: Use rawBody for signature verification
    let event;
    try {
      // Use req.rawBody if available (most reliable), otherwise req.body
      const payload = req.rawBody || req.body;

      if (!Buffer.isBuffer(payload)) {
        console.error('❌ Payload is not a Buffer:', typeof payload);
        console.error('This will cause signature verification to fail!');
        // Try to convert if it's a string
        const bufferPayload = typeof payload === 'string' ? Buffer.from(payload) : payload;
        event = stripeService.verifyWebhookSignature(bufferPayload, signature);
      } else {
        event = stripeService.verifyWebhookSignature(payload, signature);
      }

    } catch (err) {
      console.error('❌ Webhook signature verification failed:', err.message);
      return res.status(400).send(`Webhook Error: ${err.message}`);
    }

    console.log('✅ Webhook Verified:', event.type);
    console.log('📋 Event ID:', event.id);

    // Handle different event types
    switch (event.type) {
      case 'checkout.session.completed':
        console.log('💳 Processing checkout.session.completed...');
        await handleStripeCheckoutCompleted(event.data.object);
        break;

      case 'payment_intent.succeeded':
        console.log('💰 Processing payment_intent.succeeded...');
        await handleStripePaymentSucceeded(event.data.object);
        break;

      case 'payment_intent.payment_failed':
        console.log('❌ Processing payment_intent.payment_failed...');
        await handleStripePaymentFailed(event.data.object);
        break;

      case 'charge.refunded':
        console.log('💸 Processing charge.refunded...');
        await handleStripeRefund(event.data.object);
        break;

      default:
        console.log(`ℹ️ Unhandled Stripe event type: ${event.type}`);
    }

    // ✅ ALWAYS return 200 to acknowledge receipt
    res.json({ received: true });

  } catch (error) {
    console.error('❌ Stripe Webhook Error:', {
      message: error.message,
      stack: error.stack?.split('\n').slice(0, 3).join('\n')
    });

    // Still return 200 to prevent Stripe retries for unrecoverable errors
    res.status(200).json({
      received: true,
      error: 'Webhook processing failed but acknowledged'
    });
  }
});

