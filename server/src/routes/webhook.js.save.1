async function checkRegistrationTrigger(messageText, tenant) {
  try {
    if (!messageText || typeof messageText !== 'string') return null;

    // ✅ Keep original case for comparison
    const userMessage = messageText.trim();

    console.log('🔍 Checking registration trigger:', {
      originalText: messageText,
      userMessage,
      tenantId: tenant._id
    });

    const configs = await RegistrationConfig.find({
      tenantId: tenant._id,
      isActive: true
    });

    for (const config of configs) {
      // ✅ Don't convert trigger words to lowercase during retrieval
      const triggerWords = Array.isArray(config.triggerWord)
        ? config.triggerWord.map(w => w.trim())
        : String(config.triggerWord).split(',').map(w => w.trim());

      console.log('📋 Checking trigger words for config:', triggerWords);

      // ✅ Case-insensitive comparison
      if (triggerWords.some(word => {
        const wordLower = word.toLowerCase();
        const messageLower = userMessage.toLowerCase();
        return messageLower === wordLower || messageLower.includes(wordLower);
      })) {
        console.log('✅ Matched trigger word:', { userMessage, triggerWords });
        await config.incrementScanCount();
        return config;
      }
    }

    console.log('❌ No registration trigger match found');
    return null;

  } catch (error) {
    console.error('❌ Error checking registration trigger:', error);
    return null;
  }
}

async function handleFlowCompletion(messageData, tenant, metadata) {
  try {
    console.log('Processing flow completion:', {
      from: messageData.from,
      type: messageData.type,
      interactiveType: messageData.interactive?.type,
      hasResponseJson: !!messageData.interactive?.nfm_reply?.response_json
    });

    const flowReply = messageData.interactive?.nfm_reply;

    if (!flowReply) {
      console.error('No flow reply data found');
      return;
    }

    let flowResponseData = {};

    if (flowReply.response_json) {
      try {
        flowResponseData = JSON.parse(flowReply.response_json);
        console.log('Flow response data parsed:', {
          flowToken: flowResponseData.flow_token?.substring(0, 8) + '...' || 'none',
          status: flowResponseData.status,
          tenantId: flowResponseData.tenant_id,
          orderConfirmed: flowResponseData.order_confirmed
        });
      } catch (parseError) {
        console.error('Error parsing flow response JSON:', parseError);
        flowResponseData = {
          status: 'completed',
          flow_token: 'unknown',
          tenant_id: tenant._id.toString()
        };
      }
    } else {
      console.warn('No response JSON in flow completion');
      flowResponseData = {
        status: 'completed',
        flow_token: 'no_response_json',
        tenant_id: tenant._id.toString()
      };
    }

    if (flowResponseData.flow_token && flowResponseData.flow_token !== 'unknown') {
      try {

        const updatedToken = await FlowToken.markAsUsed(
          tenant._id.toString(),
          flowResponseData.flow_token,
          flowResponseData
        );

        if (updatedToken) {
          console.log('Flow token marked as used:', {
            token: flowResponseData.flow_token.substring(0, 8) + '...',
            phoneNumber: updatedToken.phoneNumber
          });
        } else {
          console.warn('Flow token not found or already used');
        }
      } catch (tokenError) {
        console.error('Error updating flow token:', tokenError);
      }
    }

    if (flowResponseData.status === 'completed' || flowResponseData.order_confirmed) {
      try {
        const whatsappService = new WhatsAppService(tenant);

        let acknowledgmentMessage;

        if (flowResponseData.order_confirmed) {
          acknowledgmentMessage = `Thank you! Your order has been confirmed successfully.\n\n` +
            `Order ID: ${flowResponseData.order_id || 'Will be provided shortly'}\n` +
            `We'll send you regular updates about your order status.\n\n` +
            `Need help? Just reply to this message.`;
        } else {
          acknowledgmentMessage = `Thank you! Your information has been received and is being processed.\n\n` +
            `We'll get back to you shortly with the next steps.`;
        }

        const ackResponse = await whatsappService.sendMessage(messageData.from, acknowledgmentMessage);

        if (ackResponse) {
          console.log('Flow completion acknowledgment sent:', {
            messageId: ackResponse.messages?.[0]?.id,
            recipient: messageData.from
          });

          const ackMessage = new Message({
            tenantId: tenant._id,
            from: metadata.phone_number_id,
            to: messageData.from,
            text: acknowledgmentMessage,
            type: 'text',
            timestamp: new Date(),
            messageId: ackResponse.messages?.[0]?.id,
            status: 'sent',
            isFlowAcknowledgment: true,
            flowToken: flowResponseData.flow_token
          });

          await ackMessage.save();

          if (global.io) {
            global.io.to(tenant._id.toString()).emit('message_sent', {
              ...ackMessage.toObject(),
              contact: { phone_number: messageData.from }
            });
          }
        }
      } catch (ackError) {
        console.error('Error sending flow completion acknowledgment:', ackError);
      }
    }

    if (global.io) {
      global.io.to(tenant._id.toString()).emit('flow_completed', {
        phoneNumber: messageData.from,
        flowData: flowResponseData,
        completedAt: new Date(),
        tenantId: tenant._id,
        orderConfirmed: flowResponseData.order_confirmed || false,
        orderId: flowResponseData.order_id || null
      });

      console.log('Flow completion event emitted to admin panel');
    }

    await updateFlowUsageStats(tenant._id.toString(), 'order_completion');

  } catch (error) {
    console.error('Critical error handling flow completion:', {
      error: error.message,
      stack: error.stack,
      messageData: messageData,
      tenantId: tenant._id
    });

    try {
      const whatsappService = new WhatsAppService(tenant);

      const errorMessage = `We encountered an issue processing your request. Our team has been notified and will assist you shortly.\n\nPlease try again or contact support if the issue persists.`;

      await whatsappService.sendMessage(messageData.from, errorMessage);
      console.log('Error acknowledgment sent to user');
    } catch (errorMsgError) {
      console.error('Failed to send error acknowledgment:', errorMsgError);
    }
  }
}

async function sendPaymentMessage(calculation, messageData, tenant, metadata) {
  try {
    const orderId = calculation.orderDetails.orderId;
    console.log('PAYMENT: Processing for order:', orderId);

    // 1. Fetch Settings & Check if Enabled
    const Settings = require('../models/settings');
    const settings = await Settings.findOne({ tenant_id: tenant._id.toString() });

    const paymentConfig = settings?.automationConfig?.paymentRequest;

    if (paymentConfig && paymentConfig.enabled === false) {
        console.log('🔕 Payment Request disabled for tenant');
        return;
    }

    // Determine Razorpay Config Name (New > Old)
    const razorpayConfigName = paymentConfig?.paymentConfigurationName || settings?.flowConfig?.paymentConfigurationName;

    if (!razorpayConfigName) {
      console.log('❌ No Razorpay config name found in settings');
      return;
    }

    // 2. Get Order Data
    const Order = require('../models/Order');
    const order = await Order.findOne({ tenantId: tenant._id.toString(), orderId: orderId });
    if (!order) throw new Error('Order not found');

    // 3. Prepare Payment Data
    // Use selected shipping cost + order amount if available, or fall back to order total
    const totalAmount = calculation.selectedShipping?.totalCost || order.totalAmount;
    const amountInPaise = Math.round(totalAmount * 100);

    const paymentOrderPayload = {
      reference_id: order.orderId,
      type: 'physical-goods',
      currency: 'INR',
      total_amount: { value: amountInPaise, offset: 100 },
      payment_settings: [{
        type: 'payment_gateway',
        payment_gateway: {
          type: 'razorpay',
          configuration_name: razorpayConfigName,
          razorpay: {
            receipt: `receipt_${order.orderId}`,
            notes: {
              order_id: order.orderId,
              tenant_id: tenant._id.toString(),
              type: 'ecommerce'
            }
          }
        }
      }],
      order: {
        status: 'pending',
        items: [{
            name: `Order ${order.orderId}`,
            amount: { value: amountInPaise, offset: 100 },
            quantity: 1
        }],
        subtotal: { value: amountInPaise, offset: 100 }
      }
    };

    // 4. Prepare Custom Message Content
    const customMessage = {
        header: paymentConfig?.template?.header || '💳 Complete Your Payment',
        body: paymentConfig?.template?.body || 'Please complete your payment.',
        footer: paymentConfig?.template?.footer || 'Powered by GoWhats!'
    };

    // Replace variables in body text
    customMessage.body = customMessage.body
        .replace('{{amount}}', `₹${totalAmount.toFixed(2)}`)
        .replace('{{order_id}}', order.orderId);

    // 5. Send via WhatsApp Service
    const whatsappService = new WhatsAppService(tenant);
    const response = await whatsappService.sendPaymentOrderDetails(
        messageData.from,
        paymentOrderPayload,
        customMessage
    );

    // 6. Save Message & Emit Socket Event
    if (response) {
       console.log('✅ Payment link sent successfully');

       const Message = require('../models/Message');
       const Contact = require('../models/Contact');

       // Save to Database
       const paymentMessage = new Message({
            tenantId: tenant._id,
            from: metadata?.phone_number_id || tenant.whatsappConfig?.phoneNumberId || 'system',
            to: messageData.from,
            text: `Payment Link sent: ${customMessage.header} - ₹${totalAmount.toFixed(2)}`,
            type: 'interactive',
            subType: 'order_details',
            timestamp: new Date(),
            messageId: response.messages?.[0]?.id,
            status: 'sent',
            isPaymentMessage: true,
            isAutomatedMessage: true,
            orderId: order.orderId,
            orderData: {
                orderId: order.orderId,
                total: totalAmount.toString(),
                currency: 'INR',
                status: 'pending_payment'
            }
       });

       await paymentMessage.save();

       // Update Contact
       await Contact.findOneAndUpdate(
        {
          tenantId: tenant._id.toString(),
          phone_number: messageData.from
        },
        {
          $set: {
            lastMessage: `Payment Link - Order #${order.orderId}`,
            timestamp: new Date()
          }
        },
        { upsert: true }
      );

       // Emit to Socket for Real-time UI
       if (global.io) {
          global.io.to(tenant._id.toString()).emit('message_sent', {
            ...paymentMessage.toObject(),
            contact: { phone_number: messageData.from }
          });

          global.io.to(tenant._id.toString()).emit('payment_order_sent', {
            customerPhone: messageData.from,
            orderId: order.orderId,
            amount: totalAmount,
            tenantId: tenant._id
          });
       }
    }

  } catch (error) {
    console.error('PAYMENT: Error sending payment link:', error.message);

    // Optional: Send text fallback on error
    try {
        const whatsappService = new WhatsAppService(tenant);
        await whatsappService.sendMessage(
            messageData.from,
            `We calculated your total as ₹${calculation.selectedShipping?.totalCost}. However, we couldn't generate the payment link. Our team will contact you shortly.`
        );
    } catch(e) { /* ignore fallback error */ }
  }
}

  const handleInteractiveMessageResponse = async (messageData, tenant, metadata) => {
  try {
    const interactiveData = messageData.interactive;
    let selectedOption = null;
    let selectedId = null;

    if (interactiveData?.type === 'button_reply') {
      selectedOption = interactiveData.button_reply?.title;
      selectedId = interactiveData.button_reply?.id;
    } else if (interactiveData?.type === 'list_reply') {
      selectedOption = interactiveData.list_reply?.title;
      selectedId = interactiveData.list_reply?.id;
    }

    console.log('🔄 Interactive response received:', {
      type: interactiveData?.type,
      selectedOption,
      selectedId,
      from: messageData.from,
    });

    if (!selectedOption) {
      console.log('❌ No valid interactive selection found. Aborting.');
      return;
    }

    // =================================================================
    // PRIORITY 1: Handle Shipping Partner Selection
    // =================================================================
    if (selectedId && selectedId.startsWith('shipping_')) {
      console.log('🚚 Customer selected a courier. Processing shipping...');
      try {
        const methodId = selectedId.replace('shipping_', '');
        const ShippingCalculation = require('../models/ShippingCalculation');
        const Order = require('../models/Order');
        const Contact = require('../models/Contact');
        // const Message = require('../models/Message'); // Not needed if we skip confirmation text

        const calculation = await ShippingCalculation.findOne({
          tenantId: tenant._id.toString(),
          customerPhone: messageData.from,
          calculationStatus: { $in: ['pending', 'calculated'] },
        }).sort({ createdAt: -1 });

        if (!calculation) {
          console.error('❌ No active shipping calculation found for this customer.');
          return;
        }

        const selectedShippingOption = calculation.availableShippingOptions.find((opt) => opt.methodId.toString() === methodId);

        if (!selectedShippingOption || !selectedShippingOption.isEligible) {
          console.error('❌ Selected shipping option is not found or not eligible.');
          return;
        }

        let finalShippingCost = selectedShippingOption.shippingCost;
        let shippingMethodName = selectedShippingOption.methodName;

        if (calculation.shouldApplyFreeShipping()) {
          finalShippingCost = 0;
          shippingMethodName = `${selectedShippingOption.methodName} (FREE SHIPPING)`;
        }

        // 1. Update Calculation
        await calculation.selectShippingMethod(selectedShippingOption.methodId, shippingMethodName, finalShippingCost);

        // 2. Update Order
        if (calculation.orderId) {
          await Order.findOneAndUpdate({ orderId: calculation.orderId, tenantId: tenant._id.toString() }, {
            $set: {
              shippingCost: finalShippingCost,
              totalAmount: calculation.selectedShipping.totalCost,
              shippingMethod: { name: shippingMethodName, cost: finalShippingCost, estimatedDays: selectedShippingOption.estimatedDays, providerId: selectedShippingOption.methodId, },
              status: 'shipping_selected',
            },
          });
        }

        // 3. ✅ DIRECTLY SEND PAYMENT MESSAGE (Skipping Confirmation Text)
        console.log('▶️ Shipping selected. Sending payment message immediately...');

        // Pass the updated calculation to the payment function
        // Note: Ensure sendPaymentMessage is defined in your webhook.js file scope
        await sendPaymentMessage(calculation, messageData, tenant, metadata);

      } catch (shippingError) {
        console.error('❌ CRITICAL ERROR during shipping selection process:', shippingError);
        const whatsappService = new WhatsAppService(tenant);
        await whatsappService.sendMessage(messageData.from, "We're sorry, an unexpected error occurred. Our team has been notified.");
      }
      return; // Stop execution here
    }

    // =================================================================
    // PRIORITY 2: Handle Bot Workflow Buttons (Existing Logic)
    // =================================================================
    const BotConfiguration = require('../models/WelcomeTemplates');
    const botConfig = await BotConfiguration.findOne({
      tenant_id: tenant._id.toString(),
      isActive: true,
    });

    if (!botConfig) {
      console.log('No active bot configuration found for other interactive replies.');
      return;
    }

    const selectedWorkflow = botConfig.workflows.find(wf => wf.buttonText === selectedOption);

    if (!selectedWorkflow) {
      console.log(`⚠️ Unhandled interactive option: "${selectedOption}"`);
      return;
    }

    const whatsappService = new WhatsAppService(tenant);
    let responseMessageText = '';

    switch (selectedWorkflow.workflow) {
      case 'Visit Website': {
        const visitWebsiteMsg = botConfig.workflowMessages?.find(wm => wm.workflow === 'Visit Website');
        responseMessageText = visitWebsiteMsg?.message || `Here is our website: https://srfoodproducts.com 🙏`;
        break;
      }
      case 'Shop Our Collection': {
        const shopWorkflowMsg = botConfig.workflowMessages?.find(wm => wm.workflow === 'Shop Our Collection');
        const catalogConfig = {
            bodyText: shopWorkflowMsg?.message || "Welcome to our collection!",
            footerText: "Powered by GoWhats!"
        };
        await whatsappService.sendCatalogMessage(messageData.from, catalogConfig);
        return;
      }
      case 'Talk with Our Team': {
        const talkWorkflowMsg = botConfig.workflowMessages?.find(wm => wm.workflow === 'Talk with Our Team');
        responseMessageText = talkWorkflowMsg?.message || "Our team will be with you shortly!";
        await Contact.findOneAndUpdate(
            { tenantId: tenant._id.toString(), phone_number: messageData.from },
            { $set: { botMode: false } }
        );
        break;
      }
      case 'Product Suggestions': {
          const suggestionMsg = botConfig.workflowMessages?.find(wm => wm.workflow === 'Product Suggestions');
          responseMessageText = suggestionMsg?.message || "AI Assistant activated! How can I help?";
          await Contact.findOneAndUpdate(
              { tenantId: tenant._id.toString(), phone_number: messageData.from },
              { $set: { botMode: true } }
          );
          break;
      }
      default:
        console.log(`- Unhandled workflow action: ${selectedWorkflow.workflow}`);
        return;
    }

    if (responseMessageText) {
      const response = await whatsappService.sendMessage(messageData.from, responseMessageText);
      if (response && response.messages?.[0]?.id) {
        const responseMessageDoc = new Message({
            tenantId: tenant._id,
            from: metadata.phone_number_id,
            to: messageData.from,
            text: responseMessageText,
            timestamp: new Date(),
            messageId: response.messages[0].id,
            status: 'sent',
            type: 'text',
            isAutomatedMessage: true,
            workflowTriggered: selectedWorkflow.workflow,
        });
        await responseMessageDoc.save();
        if (global.io) {
            global.io.to(tenant._id.toString()).emit('message_sent', {
                ...responseMessageDoc.toObject(),
                contact: { phone_number: messageData.from }
            });
        }
      }
    }

  } catch (error) {
    console.error('❌ FATAL ERROR in handleInteractiveMessageResponse:', error);
  }
};

// Helper function to create shipping confirmation message
function createShippingConfirmationMessage(calculation, orderId, selected, customerAddress) {
  const orderAmount = calculation.orderDetails.orderAmount;
  const shippingCost = selected.shippingCost;
  const totalCost = selected.totalCost;
  const itemCount = calculation.orderDetails.itemCount || 1;

  let shippingDisplay;
  if (shippingCost === 0) {
    const originalOption = calculation.availableShippingOptions.find(
      opt => opt.methodId.toString() === selected.methodId.toString()
    );

    if (originalOption && originalOption.isFreeShipping) {
      shippingDisplay = "🆓 FREE SHIPPING";
    } else {
      shippingDisplay = "₹0.00 (Free)";
    }
  } else {
    shippingDisplay = `₹${shippingCost.toFixed(2)}`;
  }

  const message = `🚚 *Shipping Method Confirmed!*

Dear ${customerAddress.name || 'Customer'}, your shipping details have been confirmed.

📦 *Order Details:*
- Order ID: *${orderId}*
- Items: ${itemCount} item(s)
- Order Amount: ₹${orderAmount.toFixed(2)}
- Shipping: ${shippingDisplay}
- *Total Amount: ₹${totalCost.toFixed(2)}*

🚚 *Delivery Method:* ${selected.methodName}
📍 *Delivery Address:*
${customerAddress.addressLine1}
${customerAddress.city}, ${customerAddress.state} - ${customerAddress.pincode}

💡 Your payment link will be sent shortly to complete the order.

_Powered by GoWhats!_`;

  return message;
}

// MAIN ROUTER POST HANDLER
router.post('/', attachTenant, async (req, res) => {
  try {
    const { body, tenant } = req;
    if (!tenant) {
      console.error('❌ Tenant not found in request, aborting.');
      return res.sendStatus(404);
    }

    const entry = body.entry?.[0];
    const changes = entry?.changes?.[0];
    const value = changes?.value;
    const field = changes?.field;

    // ============================================
    // 1. Handle WhatsApp Business App Webhooks (System)
    // ============================================

    if (field === 'history') {
      console.log('📜 History webhook received');
      try {
        await handleHistoryWebhook(value, tenant._id.toString());
        return res.sendStatus(200);
      } catch (error) {
        console.error('❌ Error processing history webhook:', error);
        return res.sendStatus(200);
      }
    }

    if (field === 'smb_app_state_sync') {
      console.log('👥 Contacts sync webhook received');
      try {
        await handleContactsSyncWebhook(value, tenant._id.toString());
        return res.sendStatus(200);
      } catch (error) {
        console.error('❌ Error processing contacts sync webhook:', error);
        return res.sendStatus(200);
      }
    }

    if (field === 'smb_message_echoes') {
      console.log('💬 Message echo webhook received');
      try {
        await handleMessageEchoesWebhook(value, tenant._id.toString());
        return res.sendStatus(200);
      } catch (error) {
        console.error('❌ Error processing message echo webhook:', error);
        return res.sendStatus(200);
      }
    }

    if (field === 'account_update') {
      console.log('⚙️ Account update webhook received');
      try {
        await handleAccountUpdateWebhook(value, tenant._id.toString());
        return res.sendStatus(200);
      } catch (error) {
        console.error('❌ Error processing account update webhook:', error);
        return res.sendStatus(200);
      }
    }

    // ============================================
    // 2. Handle Status Updates (Blue Ticks)
    // ============================================
    if (value?.statuses) {
      for (const status of value.statuses) {

        // A. Handle Payment Status
        if (status.type === 'payment') {
          console.log('💳 Payment status webhook received');
          try {
            await handlePaymentStatusUpdate(status, tenant, value.metadata);
          } catch (paymentError) {
            console.error('❌ Error processing payment status:', paymentError);
          }
          continue;
        }

        // B. Handle Message Status (Sent, Delivered, Read, Failed)
        const messageId = status.id;
        const newStatus = status.status;

        try {
          // 1. Update Database
          const message = await Message.findOneAndUpdate(
            { messageId: messageId },
            {
              $set: {
                status: newStatus,
                updatedAt: new Date(),
                // If read, capture the timestamp
                ...(newStatus === 'read' ? { readAt: new Date() } : {})
              }
            },
            { new: true }
          );

          if (message) {
            // 2. ✅ CRITICAL FIX: Emit Real-Time Socket Event to UI
            if (global.io) {
              console.log(`📡 Emitting status update: ${newStatus} for ${messageId}`);

              // Emit to the tenant room so all agents see the tick update
              global.io.to(tenant._id.toString()).emit('message_status_update', {
                messageId: message.messageId, // The ID used in frontend key
                _id: message._id,             // MongoDB ID
                status: newStatus,
                phoneNumber: message.to       // Helps frontend identify contact
              });
            }

            // 3. Handle Broadcast Logic (Existing)
            if (message.broadcastId) {
              await updateBroadcastStatusWithRealTimeEmit(
                message.broadcastId,
                messageId,
                newStatus,
                message.to,
                message.tenantId
              );
            }
          }
        } catch (error) {
          console.error(`❌ Error updating status for ${messageId}:`, error.message);
        }
      }
      return res.sendStatus(200);
    }


    // ============================================
    // 3. Handle System Messages (Identity Changes)
    // ============================================
    if (value?.messages?.[0]?.type === 'system') {
      const systemMessage = value.messages[0];
      const systemData = systemMessage.system;

      console.log('📱 System message received:', {
        type: systemData?.type,
        from: systemMessage.from,
        tenantId: tenant._id
      });

      try {
        const newSystemMessage = new Message({
          tenantId: tenant._id,
          from: systemMessage.from,
          to: value.metadata.phone_number_id,
          messageId: systemMessage.id,
          type: 'system',
          systemMessage: {
            type: systemData?.type,
            body: systemData?.body,
            wa_id: systemData?.wa_id,
            identity: systemData?.identity,
            customer: systemData?.customer
          },
          timestamp: new Date(parseInt(systemMessage.timestamp) * 1000),
          status: 'received'
        });

        await newSystemMessage.save();

        if (systemData?.type === 'user_changed_number' && systemData?.wa_id) {
            await Contact.findOneAndUpdate(
                { tenantId: tenant._id.toString(), phone_number: systemMessage.from },
                { $set: { phone_number: systemData.wa_id, previousPhoneNumber: systemMessage.from } }
            );
        }

        if (global.io) {
          global.io.to(tenant._id.toString()).emit('system_message_received', {
            message: newSystemMessage.toObject(),
            tenantId: tenant._id
          });
        }
      } catch (error) {
        console.error('❌ Error saving system message:', error);
      }
      return res.sendStatus(200);
    }


    // ============================================
    // 4. Handle Incoming User Messages
    // ============================================
    if (value?.messages?.[0]) {
      const messageData = value.messages[0];
      const contactData = value.contacts?.[0];
      const metadata = value.metadata;

      console.log('💬 Incoming message received:', {
        from: messageData.from,
        type: messageData.type,
        tenantId: tenant._id,
      });

       // A. Create/Update Contact
      const contact = await handleContactForWebhook(messageData, contactData, tenant);
      const isNewContact = !contact.lastMessage || contact.createdAt.getTime() === contact.updatedAt.getTime();

      // B. Save Message
      const messageDetails = await processMessageByType(messageData, tenant, metadata);
      const newMessage = new Message({
        tenantId: tenant._id,
        from: messageData.from,
        to: metadata.phone_number_id,
        ...messageDetails,
        timestamp: new Date(parseInt(messageData.timestamp) * 1000),
        messageId: messageData.id,
        type: messageData.type,
        status: 'received',
      });
      await newMessage.save();

      // C. Emit to UI
      emitMessageToSocket(tenant, newMessage, contact, metadata);

        try {
          await redisService.deletePattern(`contacts:${tenant._id}:*`);
          await redisService.deletePattern(`contacts:counts:${tenant._id}`);
        } catch (cacheError) {
          console.error('Redis cache clear failed:', cacheError);
        }

      // =================================================================
      // 🚦 TRAFFIC CONTROLLER: LOGIC ROUTING
      // =================================================================

      // ✅ PRIORITY 1: FLOW COMPLETION (nfm_reply)
      // Determine if this is a Registration (Booking) or E-commerce Order
      if (messageData.type === 'interactive' && messageData.interactive?.type === 'nfm_reply') {
          try {
              const reply = messageData.interactive.nfm_reply;
              const responseJson = JSON.parse(reply.response_json);
              const flowToken = responseJson.flow_token;

              const FlowToken = require('../models/FlowToken');
              const tokenRecord = await FlowToken.findOne({ token: flowToken });

              console.log('🔍 Token debug:', {
                  flowToken: flowToken?.substring(0, 12),
                  tokenFound: !!tokenRecord,
                  tokenFlowType: tokenRecord?.flowType,
                  tokenConfigId: tokenRecord?.registrationConfigId
              });

              if (tokenRecord && tokenRecord.flowType === 'registration') {
                  // ➡️ REGISTRATION FLOW
                  console.log('🔀 Routing to Booking Automation');

                  let regConfig;
                  if (tokenRecord.registrationConfigId) {
                      regConfig = await RegistrationConfig.findById(tokenRecord.registrationConfigId);
                  }
                  if (!regConfig) {
                      regConfig = await RegistrationConfig.findOne({ tenantId: tenant._id, isActive: true });
                  }

                  if (regConfig) {
                      await handleRegistrationFlowCompletion(messageData, tenant, metadata, regConfig, responseJson);
                  } else {
                      console.error('❌ Registration config not found');
                  }

              } else if (tokenRecord && tokenRecord.flowType === 'order_completion') {
                  // ➡️ ORDER FLOW
                  console.log('🔀 Routing to Order Automation');
                  await handleFlowCompletionWithShipping(messageData, tenant, metadata);

              } else {
                  // ➡️ NO TOKEN FOUND - FALLBACK using response JSON fields
                  console.log('⚠️ No token found, using fallback detection...');

                  const hasRegistrationFields =
                      responseJson.num_participants !== undefined ||
                      responseJson.participants !== undefined;

                  const hasOrderFields =
                      responseJson.order_total !== undefined ||
                      responseJson.address !== undefined;

                  if (hasRegistrationFields) {
                      console.log('🔀 Fallback: Routing to Registration');
                      let regConfig = await RegistrationConfig.findOne({
                          tenantId: tenant._id, isActive: true
                      });
                      if (regConfig) {
                          await handleRegistrationFlowCompletion(messageData, tenant, metadata, regConfig, responseJson);
                      }
                  } else if (hasOrderFields) {
                      console.log('🔀 Fallback: Routing to Order');
                      await handleFlowCompletionWithShipping(messageData, tenant, metadata);
                  } else {
                      console.log('⚠️ Cannot determine flow type - defaulting to Order');
                      await handleFlowCompletionWithShipping(messageData, tenant, metadata);
                  }
              }

          } catch (flowError) {
              console.error('❌ Error routing flow response:', flowError);
          }
          return res.sendStatus(200);
        }

      // ✅ PRIORITY 2: TEXT MESSAGE HANDLERS
      if (messageData.type === 'text' && messageData.text?.body) {

        // 2a. Check Registration Triggers (High Priority)
        const RegistrationConfig = require('../models/RegistrationConfig');
        const registrationConfig = await checkRegistrationTrigger(messageData.text.body, tenant);

        if (registrationConfig) {
          console.log('🎯 Registration Trigger Detected');
          await sendRegistrationFlow(messageData.from, registrationConfig, tenant, metadata);
          return res.sendStatus(200);
        }

        // 2b. Check Bot / AI / Welcome
        const { shouldRespond, responseType } = await shouldSendBotResponse(
          messageData,
          tenant,
          contact,
          isNewContact
        );

        if (shouldRespond) {
          switch (responseType) {
            case 'welcome':
              console.log('▶️ Sending Welcome Message');
              await sendWelcomeMessage(messageData.from, tenant, metadata);
              break;
            case 'ai_response':
              console.log('▶️ Sending AI Response');
              await handleBotResponse(messageData, tenant, metadata);
              break;
            case 'human_agent':
              console.log('▶️ Handling Human Agent Request');
              await handleHumanAgentRequest(messageData, tenant, metadata);
              break;
          }
        }
      }

     // ✅ PRIORITY 2b: BUTTON (template button replies like "Book Now")
      if (messageData.type === 'button') {
        const buttonText = messageData.button?.text || '';
        console.log('🔘 Button message received:', buttonText);

        if (buttonText) {
          // Check registration trigger first
          const registrationConfig = await checkRegistrationTrigger(buttonText, tenant);
          if (registrationConfig) {
            console.log('🎯 Registration Trigger from Button:', buttonText);
            await sendRegistrationFlow(messageData.from, registrationConfig, tenant, metadata);
            return res.sendStatus(200);
          }

          // Also run through bot/welcome logic
          const fakeTextMessage = {
            ...messageData,
            type: 'text',
            text: { body: buttonText }
          };
          const { shouldRespond, responseType } = await shouldSendBotResponse(
            fakeTextMessage, tenant, contact, isNewContact
          );
          if (shouldRespond) {
            switch (responseType) {
              case 'welcome':
                await sendWelcomeMessage(messageData.from, tenant, metadata);
                break;
              case 'ai_response':
                await handleBotResponse(fakeTextMessage, tenant, metadata);
                break;
              case 'human_agent':
                await handleHumanAgentRequest(messageData, tenant, metadata);
                break;
            }
          }
        }
        return res.sendStatus(200);
      }

      // ✅ PRIORITY 3: INTERACTIVE (Buttons/Lists, NOT Flows)
      if (messageData.type === 'interactive' && messageData.interactive?.type !== 'nfm_reply') {
        console.log('▶️ Handling Interactive Button/List Response');
        await handleInteractiveMessageResponse(messageData, tenant, metadata);
        return res.sendStatus(200);
      }

      // ✅ PRIORITY 4: CATALOG ORDERS (Native WhatsApp Commerce)
      if (messageData.type === 'order') {
        console.log('▶️ Handling Catalog Order');

        // =========================================================
        // 🛒 START ABANDONED CART TIMER
        // =========================================================
        try {
            // Check if we have order data from processMessageByType
            if (messageDetails && messageDetails.orderData && messageDetails.orderData.raw_order_data) {
                console.log(`🛒 Triggering Abandoned Cart Timer for ${messageData.from}`);

                await abandonedCartService.handleIncomingCart(
                    tenant,
                    messageData.from,
                    messageDetails.orderData.raw_order_data
                );
            } else {
                console.warn('⚠️ Missing order data for abandoned cart trigger');
            }
        } catch (cartError) {
            console.error('❌ Failed to trigger abandoned cart timer:', cartError);
        }
        // =========================================================

        await sendOrderFlowMessage(messageDetails.orderData, messageData, tenant, metadata);
        return res.sendStatus(200);
      }

      return res.sendStatus(200);
    }

    // If no specific webhook type matched, return 200
    return res.sendStatus(200);

  } catch (error) {
    console.error('❌ Webhook Error:', error);
    return res.sendStatus(500);
  }
});


