        count: participantCount,
        orderId: registrationOrderId,
        amount: totalAmount
      });
    }

    console.log('✅ ====== REGISTRATION FLOW COMPLETED SUCCESSFULLY ======');

  } catch (error) {
    console.error('❌ Dynamic Registration Logic Error:', error);
  }
}

async function generateAndSendMultipleTickets(tenant, phoneNumber, count, config, customerName, flowData, orderId = null) {
  try {
    console.log(`🎟️ ====== TICKET GENERATION START (Count: ${count}) ======`);

    // 1. Lock to prevent duplicates
    const processingKey = `${tenant._id}-${orderId || phoneNumber}`;
    if (processingTickets.has(processingKey)) {
      return false; // Already processing
    }
    processingTickets.set(processingKey, Date.now());

    // Auto-clear lock
    setTimeout(() => { if (processingTickets.has(processingKey)) processingTickets.delete(processingKey); }, 60000);

    const createdTickets = [];

    // 2. Create individual database records (for backend reporting)
    // We do this loop purely for DB, NOT for sending messages
    for (let i = 0; i < count; i++) {
      let ticketId = await config.generateNextTicketId();

      const newTicket = new EventTicket({
        tenantId: tenant._id.toString(),
        ticketId: ticketId,
        orderId: orderId,
        customerPhone: phoneNumber,
        customerName: count > 1 ? `${customerName} (Guest ${i + 1})` : customerName,
        participantCount: 1, // Each DB entry represents 1 person slot
        flowData: flowData,
        status: 'active'
      });

      await newTicket.save();
      createdTickets.push(newTicket);
    }

    if (createdTickets.length === 0) {
      throw new Error("Failed to create ticket records");
    }

    // 3. ✅ SEND ONLY ONE MASTER QR CODE
    // We use the first ticket as the reference, but mark the count in the QR payload
    const mainTicket = createdTickets[0];
    let confirmationMessage = config.confirmationMessage || "🎉 Booking Confirmed!";

    console.log(`  📤 Sending GROUP QR code for Order ${orderId}...`);

    // Call the QR Generator with the total count
    const qrSent = await generateAndSendTicketQR(
      mainTicket,
      tenant,
      phoneNumber,
      confirmationMessage,
      count,
      config
    );

    if (qrSent) {
      console.log(`  ✅ Group QR code sent successfully`);
    } else {
      console.warn(`  ⚠️ QR code sending failed`);
    }

    // 4. Cleanup
    processingTickets.delete(processingKey);
    return qrSent;

  } catch (error) {
    console.error("❌ CRITICAL: Ticket generation failed:", error);
    const processingKey = `${tenant._id}-${orderId || phoneNumber}`;
    processingTickets.delete(processingKey);
    return false;
  }
}

module.exports = router;
