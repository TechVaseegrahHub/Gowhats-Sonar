/**
 * Handle successful checkout session
 */
async function handleStripeCheckoutCompleted(session) {
  try {
    console.log('💳 ====== PROCESSING CHECKOUT COMPLETION ======');
    console.log('Session ID:', session.id);
    console.log('Payment Status:', session.payment_status);
    console.log('Amount Total:', session.amount_total / 100);

    const sessionCurrency = session.currency?.toUpperCase() || 'SGD';

    const orderId = session.metadata.orderId;
    const tenantId = session.metadata.tenantId;
    const registrationConfigId = session.metadata.registrationConfigId;

    console.log('📋 Metadata:', { orderId, tenantId, registrationConfigId, currency: sessionCurrency });

    const Order = require('../models/Order');
    const order = await Order.findOne({ tenantId: tenantId, orderId: orderId });

    if (!order) {
      console.error('❌ Order not found:', orderId);
      return;
    }

    // ✅ Duplicate webhook guard
    if (order.paymentStatus === 'completed' && order.metadata?.ticketSent) {
      console.log('⚠️ Already processed, skipping:', orderId);
      return;
    }

    // Update order
    order.paymentStatus = 'completed';
    order.status = 'confirmed';
    order.confirmedAt = new Date();
    order.paymentDetails = {
      ...order.paymentDetails,
      gateway: 'stripe',
      status: 'completed',
      sessionId: session.id,
      amount: session.amount_total / 100,
      currency: sessionCurrency
    };
    await order.save();
    console.log('✅ Order marked completed');

    const Tenant = require('../models/Tenant');
    const tenant = await Tenant.findById(tenantId);
    if (!tenant) {
      console.error('❌ Tenant not found:', tenantId);
      return;
    }

    // ✅ Get participant count from multiple sources
    let participantCount = 1;
    if (order.participantCount && order.participantCount > 0) {
      participantCount = order.participantCount;
    } else if (order.metadata?.participantCount) {
      participantCount = parseInt(order.metadata.participantCount, 10) || 1;
    } else if (session.metadata?.participantCount) {
      participantCount = parseInt(session.metadata.participantCount, 10) || 1;
    }
    console.log(`👥 Participant Count: ${participantCount}`);

    const customerName = order.customerDetails?.name || 'Guest';
    const customerPhone = order.customerPhone;

    // ============================================================
    // ✅ REGISTRATION ORDER → Send Static Ticket Image
    // ============================================================
    if (order.source === 'registration_flow' || order.metadata?.isRegistrationOrder) {
      console.log('🎟️ Registration order — sending static ticket image...');

      const ticketSent = await sendStaticTicketImage(
        tenant,
        customerPhone,
        customerName,
        orderId,
        participantCount
      );

      // Save result to order
      if (!order.metadata) order.metadata = {};
      order.metadata.ticketSent = ticketSent;
      order.metadata.ticketSentAt = new Date();
      order.metadata.ticketsGenerated = ticketSent; // legacy flag
      await order.save();

      // Update EventTicket records if any exist
      try {
        const EventTicket = require('../models/EventTicket');
        await EventTicket.updateMany(
          { tenantId: tenantId, orderId: orderId },
          { $set: { status: 'active', paymentConfirmed: true } }
        );
      } catch (e) {
        console.log('EventTicket update skipped:', e.message);
      }

      // Increment RegistrationConfig payment count
      try {
        const RegistrationConfig = require('../models/RegistrationConfig');
        const regConfig = await RegistrationConfig.findById(registrationConfigId) ||
                          await RegistrationConfig.findOne({ tenantId: tenantId, isActive: true });
        if (regConfig) await regConfig.incrementPaymentCount();
      } catch (e) {
        console.log('RegConfig count update skipped:', e.message);
      }

      console.log(`🎟️ Ticket image sent: ${ticketSent ? '✅ SUCCESS' : '⚠️ FAILED (text fallback sen t)'}`);

    } else {
      // 📦 Normal shop order — existing logic
      console.log('📦 Standard order - sending confirmation...');
      await sendOrderConfirmationMessage(order, customerPhone, tenant, session.metadata);
    }

    // Emit real-time socket update
    if (global.io) {
      global.io.to(tenantId).emit('payment_status_update', {
        orderId: orderId,
        status: 'completed',
        gateway: 'stripe',
        currency: sessionCurrency,
        tenantId: tenantId,
        participantCount: participantCount,
        ticketSent: order.metadata?.ticketSent || false
      });
      console.log('📡 Socket event emitted');
    }

    console.log('✅ ====== CHECKOUT COMPLETION PROCESSED ======\n');

  } catch (error) {
    console.error('❌ ====== CHECKOUT HANDLER ERROR ======');
    console.error('Error:', error.message);
    console.error('Stack:', error.stack?.split('\n').slice(0, 5).join('\n'));
  }
}


